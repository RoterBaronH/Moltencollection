<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/Moltencollection/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>My Binders</title>
		<script src="/Moltencollection/auth.js" is:inline></script>
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: Arial, sans-serif;
				padding-top: 0;
				background-color: #1a1a1a;
			}
			.nav {
				display: flex;
				gap: 0;
				background-color: #333;
				padding: 0;
				margin: 0;
			}
			.nav-btn {
				flex: 1;
				padding: 15px 20px;
				background-color: #333;
				color: white;
				text-decoration: none;
				text-align: center;
				cursor: pointer;
				border: none;
				border-right: 1px solid #555;
				transition: background-color 0.3s;
			}
			.nav-btn:hover {
				background-color: #555;
			}
			.nav-btn.active {
				background-color: #0066cc;
			}
			.nav-btn:last-child {
				border-right: none;
			}
			body > h1,
			body > p {
				padding: 20px;
				max-width: 1000px;
				margin: 0;
				color: #fff;
			}
			.binder-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 24px;
				padding: 24px 20px;
				max-width: 1200px;
				margin: 0;
			}
			.binder-card {
				position: relative;
				width: 150px;
				height: 180px;
			}
			.binder-card.is-draggable {
				cursor: grab;
			}
			.binder-card.is-dragging {
				opacity: 0.45;
			}
			.binder-card.is-drop-target .binder-link {
				outline: 2px dashed rgba(255, 255, 255, 0.9);
				outline-offset: 4px;
			}
			.binder-link {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 10px;
				width: 150px;
				height: 180px;
				background: var(--binder-color, #2c3e50);
				color: #fff;
				text-decoration: none;
				text-align: center;
				border-radius: 14px;
				box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
				padding: 16px 12px;
				transition: transform 0.2s, box-shadow 0.2s;
				overflow: hidden;
			}
			.binder-link:hover {
				filter: brightness(1.15);
				transform: translateY(-6px);
				box-shadow: 0 14px 24px rgba(0, 0, 0, 0.5);
			}
			.binder-link h3 {
				margin: 0;
				font-size: 1.1rem;
				font-weight: bold;
				line-height: 1.2;
				word-break: break-word;
			}
			.binder-link p {
				margin: 0;
				color: rgba(255, 255, 255, 0.85);
				font-size: 0.75rem;
				line-height: 1.3;
				max-height: 40px;
				overflow: hidden;
			}
			.edit-btn {
				position: absolute;
				bottom: 8px;
				right: 8px;
				z-index: 2;
				padding: 4px 8px;
				border: none;
				border-radius: 6px;
				background: rgba(0, 0, 0, 0.55);
				color: #fff;
				font-size: 11px;
				cursor: pointer;
				transition: background 0.2s;
			}
			.edit-btn:hover {
				background: rgba(0, 0, 0, 0.8);
			}
			.add-binder {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 10px;
				width: 150px;
				height: 180px;
				background: rgba(255, 255, 255, 0.75);
				backdrop-filter: blur(4px);
				color: #333;
				font-size: 1.25rem;
				font-weight: bold;
				line-height: 1;
				text-align: center;
				border-radius: 14px;
				border: 0;
				font-family: inherit;
				box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
				cursor: pointer;
				text-decoration: none;
				overflow: hidden;
				transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
			}
			.add-binder .plus {
				font-size: 3rem;
				line-height: 1;
			}
			.add-binder:hover {
				filter: brightness(1.15);
				background: rgba(255, 255, 255, 0.9);
				transform: translateY(-6px);
				box-shadow: 0 14px 24px rgba(0, 0, 0, 0.5);
			}
			.editor-backdrop {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.7);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				z-index: 1000;
			}
			.editor-backdrop[hidden] {
				display: none;
			}
			.editor-modal {
				width: 100%;
				max-width: 560px;
				background: #26323d;
				border: 1px solid #3a4a58;
				border-radius: 12px;
				padding: 20px;
				position: relative;
				color: #fff;
			}
			.editor-close {
				position: absolute;
				top: 10px;
				right: 10px;
				width: 30px;
				height: 30px;
				border: none;
				border-radius: 8px;
				background: #374757;
				color: #fff;
				font-size: 18px;
				line-height: 1;
				cursor: pointer;
			}
			.editor-close:hover {
				background: #4a5f73;
			}
			.editor-modal h2 {
				margin-bottom: 14px;
			}
			.editor-modal label {
				display: block;
				font-weight: 700;
				margin-bottom: 8px;
			}
			.editor-modal input,
			.editor-modal textarea {
				width: 100%;
				padding: 10px 12px;
				margin-bottom: 14px;
				border: 1px solid #55697b;
				border-radius: 8px;
				background: #1f2a33;
				color: #fff;
				font-size: 16px;
			}
			.editor-modal textarea {
				min-height: 100px;
				resize: vertical;
			}
			.editor-modal input[type='color'] {
				height: 50px;
				padding: 5px;
			}
			.editor-actions {
				display: flex;
				gap: 10px;
				margin-top: 6px;
			}
			.editor-actions button {
				padding: 10px 14px;
				border: none;
				border-radius: 8px;
				font-size: 15px;
				cursor: pointer;
			}
			#save-binder-btn {
				background: #2ea043;
				color: #fff;
			}
			#delete-binder-btn {
				background: #c03636;
				color: #fff;
			}
			#save-binder-btn {
				margin-left: auto;
			}
			.empty-state {
				color: #c8d0d8;
				font-size: 18px;
				align-self: center;
				margin-top: 10px;
			}
		</style>
	</head>
	<body>
				<!-- Viewer mode banner removed -->
		<nav class="nav">
			<a href="/Moltencollection/" class="nav-btn">Home</a>
			<a href="/Moltencollection/binders" class="nav-btn active">My Binders</a>
			<a href="/Moltencollection/deck" class="nav-btn">My Decks</a>
			<a href="/Moltencollection/collections" class="nav-btn">Collection</a>
		</nav>
		<h1>My Binders</h1>
		<p>View and manage your MTG card binders here.</p>

		<div class="binder-grid" id="binder-grid">
			<button type="button" id="open-binder-btn" class="add-binder auth-required" title="Create new binder">
				<span class="plus">+</span>
				<span>Add Binder</span>
			</button>
		</div>

		<div class="editor-backdrop" id="editor-backdrop" hidden>
			<div class="editor-modal">
				<button type="button" class="editor-close" id="close-editor-btn" aria-label="Close">&times;</button>
				<h2 id="editor-title">Create Binder</h2>
				<form id="editor-form">
					<input type="hidden" id="edit-binder-id" />

					<label for="edit-binder-name">Binder Name</label>
					<input id="edit-binder-name" type="text" maxlength="50" required />

					<label for="edit-binder-color">Color</label>
					<input id="edit-binder-color" type="color" value="#2c3e50" />

					<div class="editor-actions">
						<button type="button" id="delete-binder-btn" hidden>Delete</button>
						<button type="submit" id="save-binder-btn">Save Changes</button>
					</div>
				</form>
			</div>
		</div>

		</script>
		<script>
		// Pure JavaScript, no types
		var DEFAULT_COLOR = '#2c3e50';
		var binderGrid = document.getElementById('binder-grid');
		var openBinderButton = document.getElementById('open-binder-btn');
		var editorBackdrop = document.getElementById('editor-backdrop');
		var editorTitle = document.getElementById('editor-title');
		var editorForm = document.getElementById('editor-form');
		var editIdInput = document.getElementById('edit-binder-id');
		var editNameInput = document.getElementById('edit-binder-name');
		var editColorInput = document.getElementById('edit-binder-color');
		var deleteBinderButton = document.getElementById('delete-binder-btn');
		var closeEditorButton = document.getElementById('close-editor-btn');

		if (!binderGrid || !openBinderButton || !editorBackdrop || !editorTitle || !editorForm || !editIdInput || !editNameInput || !editColorInput || !deleteBinderButton || !closeEditorButton) {
			throw new Error('Binder page UI is missing required elements.');
		}

		function isValidColor(color) { return /^#[0-9a-fA-F]{6}$/.test(color); }
		function isStoredCard(slot) {
			if (!slot || typeof slot !== 'object') return false;
			var card = slot;
			return typeof card.id === 'string' && typeof card.name === 'string' && typeof card.scryfallUri === 'string';
		}
		function countBinderCards(binder) {
			var pages = Array.isArray(binder.pages) ? binder.pages : [];
			var count = 0;
			pages.forEach(function(page) {
				if (!Array.isArray(page)) return;
				page.forEach(function(slot) {
					if (isStoredCard(slot)) count += 1;
				});
			});
			return count;
		}
		function sanitizeBinders(input) {
			if (!Array.isArray(input)) return [];
			return input.filter(function(binder) { return binder && typeof binder === 'object'; }).map(function(binder) {
				var raw = binder;
				var color = typeof raw.color === 'string' && isValidColor(raw.color) ? raw.color : DEFAULT_COLOR;
				return {
					id: typeof raw.id === 'number' ? raw.id : Date.now() + Math.floor(Math.random() * 1000),
					name: typeof raw.name === 'string' && raw.name.trim() ? raw.name.trim() : 'Untitled Binder',
					color: color,
					pages: Array.isArray(raw.pages) ? raw.pages : []
				};
			});
		}

		var binders = [];
		// Load binders from public/data.json for viewers
		fetch('/data.json')
			.then(function(res) { return res.json(); })
			.then(function(data) {
				binders = sanitizeBinders(data.binders);
				renderBinders();
			});

		// Save binders only if authenticated
		function saveBinders() {
			if (typeof window !== 'undefined' && window.mtgIsAuthed) {
				// Save to public/data.json is not possible from client, so show a message or implement server logic if needed
				alert('Saving binders is only possible for the authenticated user and must be done via GitHub or server.');
			}
		}

		function renderBinders() {
			if (!binderGrid) return;
			binderGrid.innerHTML += '<div class="empty-state">Binders loaded.</div>';
		}

		// ...existing code for moveBinderToTarget, closeEditor, openCreateEditor, openEditor, createBinderCard, renderBinders, editorForm, closeEditorButton, deleteBinderButton, openBinderButton, editorBackdrop, document.addEventListener...
		</script>
	</body>
</html>
