			const commanderSearchTitle = document.getElementById('commander-search-title') as HTMLSpanElement;
			const commanderSearchBackBtn = document.getElementById('commander-search-back') as HTMLButtonElement;
			const commanderSearchCloseBtn = document.getElementById('commander-search-close') as HTMLButtonElement;
			const commanderSearchInput = document.getElementById('commander-search-input') as HTMLInputElement;
			const commanderSearchStatus = document.getElementById('commander-search-status') as HTMLDivElement;
			const commanderSearchResults = document.getElementById('commander-search-results') as HTMLDivElement;
