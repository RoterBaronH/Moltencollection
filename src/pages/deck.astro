			const deckCurve = document.getElementById('deck-curve') as HTMLElement;

			const metaCache: Record<string, CardMeta> = (() => {
				try {
					const raw = localStorage.getItem(META_CACHE_KEY);
					return raw ? (JSON.parse(raw) as Record<string, CardMeta>) : {};
				} catch {
					return {};
				}
			})();

			const saveMetaCache = (): void => {
				localStorage.setItem(META_CACHE_KEY, JSON.stringify(metaCache));
			};

			const readDeckNames = (): string[] => {
				try {
					const raw = localStorage.getItem(DECK_NAMES_KEY);
					const names = raw ? (JSON.parse(raw) as string[]) : [];
					if (!Array.isArray(names)) return [];
					const cleaned = names
						.map((name) => String(name).trim())
						.filter((name) => name.length > 0);
					return Array.from(new Set(cleaned));
				} catch {
					return [];
				}
			};

			const parseDeckFormat = (value: string | undefined): DeckFormat => {
				const normalized = (value ?? '').trim().toLowerCase();
				if (normalized === 'commander') return 'commander';
				if (normalized === 'standard') return 'standard';
				if (normalized === 'modern') return 'modern';
				if (normalized === 'pioneer') return 'pioneer';
				if (normalized === 'legacy') return 'legacy';
				if (normalized === 'vintage') return 'vintage';
				if (normalized === 'pauper') return 'pauper';
				if (normalized === 'brawl') return 'brawl';
				return 'custom';
			};

			const formatLabel = (format: DeckFormat): string => {
				if (format === 'commander') return 'Commander';
				if (format === 'standard') return 'Standard';
				if (format === 'modern') return 'Modern';
				if (format === 'pioneer') return 'Pioneer';
				if (format === 'legacy') return 'Legacy';
				if (format === 'vintage') return 'Vintage';
				if (format === 'pauper') return 'Pauper';
				if (format === 'brawl') return 'Brawl';
				return 'Custom';
			};

			const readDeckFormats = (): Record<string, DeckFormat> => {
				try {
					const raw = localStorage.getItem(DECK_FORMATS_KEY);
					const parsed = raw ? (JSON.parse(raw) as Record<string, string>) : {};
					if (!parsed || typeof parsed !== 'object') return {};

					const result: Record<string, DeckFormat> = {};
					Object.entries(parsed).forEach(([deckName, format]) => {
						result[deckName] = parseDeckFormat(format);
					});
					return result;
				} catch {
					return {};
				}
			};

			const saveDeckFormats = (map: Record<string, DeckFormat>): void => {
				localStorage.setItem(DECK_FORMATS_KEY, JSON.stringify(map));
			};

			const readDeckColors = (): Record<string, string> => {
				try {
					const raw = localStorage.getItem(DECK_COLORS_KEY);
					const parsed = raw ? (JSON.parse(raw) as Record<string, string>) : {};
					if (!parsed || typeof parsed !== 'object') return {};
					const result: Record<string, string> = {};
					Object.entries(parsed).forEach(([deck, color]) => {
						if (typeof color === 'string' && /^#[0-9a-fA-F]{6}$/.test(color)) {
							result[deck] = color;
						}
					});
					return result;
				} catch {
					return {};
				}
			};

			const saveDeckColors = (map: Record<string, string>): void => {
				localStorage.setItem(DECK_COLORS_KEY, JSON.stringify(map));
			};

			const readDeckCommanders = (): Record<string, SlotCard> => {
				try {
					const raw = localStorage.getItem(DECK_COMMANDERS_KEY);
					const parsed = raw ? (JSON.parse(raw) as Record<string, unknown>) : {};
					if (!parsed || typeof parsed !== 'object') return {};

					const result: Record<string, SlotCard> = {};
					Object.entries(parsed).forEach(([deckName, value]) => {
						if (!value || typeof value !== 'object') return;
						const card = value as Partial<SlotCard>;
						if (!card.id || !card.name || !card.scryfallUri) return;
						result[deckName] = {
							id: card.id,
							name: card.name,
							imageUrl: card.imageUrl ?? null,
							imageUrlLarge: card.imageUrlLarge ?? null,
							scryfallUri: card.scryfallUri,
							setCode: card.setCode,
							setName: card.setName,
							collectorNumber: card.collectorNumber,
							lang: card.lang,
							foil: card.foil ?? 'nonfoil'
						};
					});
					return result;
				} catch {
					return {};
				}
			};

			const saveDeckCommanders = (map: Record<string, SlotCard>): void => {
				localStorage.setItem(DECK_COMMANDERS_KEY, JSON.stringify(map));
			};

			const pickCardImageSmall = (card: ScryfallSearchCard): string | null => {
				if (card.image_uris?.small) return card.image_uris.small;
				const firstFace = card.card_faces?.find((face) => face.image_uris?.small);
				return firstFace?.image_uris?.small ?? null;
			};

			const pickCardImageNormal = (card: ScryfallSearchCard): string | null => {
				if (card.image_uris?.normal) return card.image_uris.normal;
				const firstFace = card.card_faces?.find((face) => !!face.image_uris?.normal);
				return firstFace?.image_uris?.normal ?? null;
			};

			const rowKeyFromCard = (card: SlotCard): string => {
				return [
					card.id,
					card.lang ?? '',
					card.foil ?? 'nonfoil',
					card.setCode ?? '',
					card.collectorNumber ?? ''
				].join('|');
			};

			const escapeScryfallRegex = (value: string): string => value.replace(/[\\^$.*+?()[\]{}|/]/g, '\\$&');

			const searchCommanderCard = async (query: string): Promise<SlotCard | null> => {
				const term = query.trim();
				if (!term) return null;
				const nameNeedle = term.toLowerCase();
				const requestCards = async (searchQuery: string): Promise<Response> => {
					return fetch(`https://api.scryfall.com/cards/search?q=${encodeURIComponent(searchQuery)}&order=released&dir=desc&unique=prints`);
				};

				let response = await requestCards(`name:/${escapeScryfallRegex(term)}/`);
				if (!response.ok && response.status !== 404) {
					response = await requestCards(`name:${term}`);
				}
				if (!response.ok) return null;

				const payload = await response.json() as { data?: ScryfallSearchCard[] };
				const first = (payload.data ?? []).find((card) => (card.name ?? '').toLowerCase().includes(nameNeedle)) ?? payload.data?.[0];
				if (!first) return null;

				return {
					id: first.id,
					name: first.name,
					imageUrl: pickCardImageSmall(first),
					imageUrlLarge: pickCardImageNormal(first),
					scryfallUri: first.scryfall_uri,
					setCode: first.set,
					setName: first.set_name,
					collectorNumber: first.collector_number,
					lang: first.lang,
					foil: 'nonfoil'
				};
			};

			const saveDeckNames = (names: string[]): void => {
				const cleaned = Array.from(new Set(names.map((name) => name.trim()).filter((name) => name.length > 0)));
				localStorage.setItem(DECK_NAMES_KEY, JSON.stringify(cleaned));
			};

			const readDeckMap = (): Map<string, SlotCard[]> => {
				try {
					const raw = localStorage.getItem(DECK_CARD_MAP_KEY);
					if (!raw) return new Map<string, SlotCard[]>();
					const parsed = JSON.parse(raw) as Record<string, SlotCard[]>;
					if (!parsed || typeof parsed !== 'object') return new Map<string, SlotCard[]>();

					const map = new Map<string, SlotCard[]>();
					Object.entries(parsed).forEach(([deckName, cards]) => {
						if (!deckName.trim()) return;
						if (!Array.isArray(cards)) {
							map.set(deckName, []);
							return;
						}
						const sanitized = cards.filter((card) => {
							return !!card && typeof card === 'object' && typeof card.id === 'string' && typeof card.name === 'string';
						});
						map.set(deckName, sanitized);
					});

					return map;
				} catch {
					return new Map<string, SlotCard[]>();
				}
			};

			const saveDeckMap = (): void => {
				const serializable: Record<string, SlotCard[]> = {};
				deckMap.forEach((cards, deckName) => {
					serializable[deckName] = cards;
				});
				localStorage.setItem(DECK_CARD_MAP_KEY, JSON.stringify(serializable));
			};

			let draggedDeckName = '';

			const moveDeckToTarget = (deckName: string, targetDeckName: string): void => {
				if (!deckName || deckName === targetDeckName) return;

				const names = readDeckNames();
				const currentIndex = names.indexOf(deckName);
				const targetIndex = names.indexOf(targetDeckName);
				if (currentIndex === -1 || targetIndex === -1) return;

				const reordered = [...names];
				const [movedDeck] = reordered.splice(currentIndex, 1);
				reordered.splice(targetIndex, 0, movedDeck);
				saveDeckNames(reordered);
				renderDeckHome();
			};

			const fallbackMeta: CardMeta = {
				cmc: 0,
				manaCost: '',
				typeLine: '',
				colorIdentity: [],
				priceEur: '',
				priceEurFoil: '',
				priceUsd: '',
				priceUsdFoil: ''
			};

			const fetchMeta = async (card: SlotCard): Promise<CardMeta> => {
				if (metaCache[card.id]) return metaCache[card.id];

				try {
					const response = await fetch(`https://api.scryfall.com/cards/${encodeURIComponent(card.id)}`);
					if (response.ok) {
						const data = await response.json() as {
							cmc?: number;
							mana_cost?: string;
							type_line?: string;
							color_identity?: string[];
							prices?: {
								eur?: string | null;
								eur_foil?: string | null;
								usd?: string | null;
								usd_foil?: string | null;
							};
						};
						metaCache[card.id] = {
							cmc: Number.isFinite(data.cmc) ? Number(data.cmc) : 0,
							manaCost: data.mana_cost ?? '',
							typeLine: data.type_line ?? '',
							colorIdentity: Array.isArray(data.color_identity) ? data.color_identity : [],
							priceEur: data.prices?.eur ?? '',
							priceEurFoil: data.prices?.eur_foil ?? '',
							priceUsd: data.prices?.usd ?? '',
							priceUsdFoil: data.prices?.usd_foil ?? ''
						};
						saveMetaCache();
						return metaCache[card.id];
					}
				} catch {
					return fallbackMeta;
				}

				metaCache[card.id] = fallbackMeta;
				return fallbackMeta;
			};

			const sectionFromType = (typeLine: string): string => {
				if (typeLine.includes('Creature')) return 'Creatures';
				if (typeLine.includes('Instant')) return 'Instants';
				if (typeLine.includes('Sorcery')) return 'Sorceries';
				if (typeLine.includes('Enchantment')) return 'Enchantments';
				if (typeLine.includes('Artifact')) return 'Artifacts';
				if (typeLine.includes('Planeswalker')) return 'Planeswalkers';
				if (typeLine.includes('Battle')) return 'Battles';
				if (typeLine.includes('Land')) return 'Lands';
				return 'Other';
			};

			const colorLabel = (symbol: string): string => {
				if (symbol === 'W') return 'White';
				if (symbol === 'U') return 'Blue';
				if (symbol === 'B') return 'Black';
				if (symbol === 'R') return 'Red';
				if (symbol === 'G') return 'Green';
				return symbol;
			};

			const deckIdentitySymbols = (deckName: string): string[] => {
				const cards = deckMap.get(deckName) ?? [];
				const used = new Set<string>();

				cards.forEach((card) => {
					const colors = metaCache[card.id]?.colorIdentity ?? [];
					colors.forEach((symbol) => {
						if (symbol === 'W' || symbol === 'U' || symbol === 'B' || symbol === 'R' || symbol === 'G') {
							used.add(symbol);
						}
					});
				});

				return ['W', 'U', 'B', 'R', 'G'].filter((symbol) => used.has(symbol));
			};

			const formatPrice = (meta: CardMeta, foil: SlotCard['foil']): { text: string; numeric: number } => {
				const isFoil = foil === 'foil' || foil === 'etched';
				const eur = isFoil ? (meta.priceEurFoil || meta.priceEur) : (meta.priceEur || meta.priceEurFoil);
				const usd = isFoil ? (meta.priceUsdFoil || meta.priceUsd) : (meta.priceUsd || meta.priceUsdFoil);

				if (eur) return { text: `EUR ${eur}`, numeric: Number.parseFloat(eur) || 0 };
				if (usd) return { text: `USD ${usd}`, numeric: Number.parseFloat(usd) || 0 };
				return { text: '-', numeric: 0 };
			};

			const collectionVariantKey = (card: SlotCard): string => {
				return [
					card.id,
					card.lang ?? '',
					card.foil ?? 'nonfoil'
				].join('|');
			};

			const emptyBinderPage = (): BinderSlotValue[] => Array(BINDER_SLOTS_PER_PAGE).fill(null);

			import { getBinders, saveBinder, getCollection, saveCollection } from '../firestoreSync';
			const username = localStorage.getItem('mtgUsername') || '';
			let binders: BinderStorage[] = [];
			getBinders(username).then((data) => {
				binders = data;
				// Optionally re-render UI here
			});

			const saveBinders = async (binders: BinderStorage[]): Promise<void> => {
				for (const binder of binders) {
					await saveBinder(username, String(binder.id), binder);
				}
			};

			let collectionCards: SlotCard[] = [];
			getCollection(username).then((data) => {
				collectionCards = data?.cards ?? [];
				// Optionally re-render UI here
			});

			const saveCollectionCards = async (cards: SlotCard[]): Promise<void> => {
				await saveCollection(username, { cards });
			};

			const ensureBinderPages = (binder: BinderStorage): BinderSlotValue[][] => {
				const pages = Array.isArray(binder.pages) ? binder.pages : [];
				while (pages.length < 2) {
					pages.push(emptyBinderPage());
				}
				for (let idx = 0; idx < pages.length; idx += 1) {
					if (!Array.isArray(pages[idx])) {
						pages[idx] = emptyBinderPage();
						continue;
					}
					if (pages[idx].length < BINDER_SLOTS_PER_PAGE) {
						pages[idx] = [...pages[idx], ...Array(BINDER_SLOTS_PER_PAGE - pages[idx].length).fill(null)];
					}
				}
				binder.pages = pages;
				return pages;
			};

			const cloneForCollection = (card: SlotCard, sourceKey: string): SlotCard => {
				return {
					id: card.id,
					name: card.name,
					imageUrl: card.imageUrl,
					imageUrlLarge: card.imageUrlLarge,
					scryfallUri: card.scryfallUri,
					setCode: card.setCode,
					setName: card.setName,
					collectorNumber: card.collectorNumber,
					lang: card.lang,
					foil: card.foil ?? 'nonfoil',
					collectionSource: sourceKey
				};
			};

			const addCardToCollection = (card: SlotCard, sourceKey: string): { ok: boolean; message: string } => {
				const collectionCards = readCollectionCards();
				// Only allow one copy per card id
				const exists = collectionCards.some((c) => c.id === card.id);
				if (exists) {
					return {
						ok: false,
						message: `${card.name} is already in your collection.`
					};
				}
				const cardToAdd = cloneForCollection(card, sourceKey);
				collectionCards.push(cardToAdd);
				saveCollectionCards(collectionCards);
				return {
					ok: true,
					message: `Added ${card.name} to collection.`
				};
			};

			const isInCollection = (card: SlotCard): boolean => {
				return readCollectionCards().some((entry) => entry.id === card.id);
			};

			const syncAddToCollectionButton = (card: SlotCard | null): void => {
				if (!card) {
					addToCollectionBtn.disabled = true;
					addToCollectionBtn.textContent = 'Add to Collection';
					addToCollectionBtn.title = 'Open a card first';
					return;
				}

				if (card.proxy) {
					addToCollectionBtn.disabled = true;
					addToCollectionBtn.textContent = 'Add to Collection';
					addToCollectionBtn.title = 'Proxy cards cannot be added to your collection.';
					return;
				}

				const alreadyCollected = isInCollection(card);
				addToCollectionBtn.disabled = alreadyCollected;
				addToCollectionBtn.textContent = alreadyCollected ? 'In Collection' : 'Add to Collection';
				addToCollectionBtn.title = alreadyCollected
					? 'This card variant is already in your collection.'
					: 'Add this card variant to your collection.';
			};

			const applyFoilClass = (element: HTMLElement, foil: SlotCard['foil'] | undefined): void => {
				element.classList.remove('preview-foil', 'preview-etched', 'inspector-foil', 'inspector-etched');
				if (foil === 'foil') {
					element.classList.add(element === commanderPreview ? 'preview-foil' : 'inspector-foil');
				} else if (foil === 'etched') {
					element.classList.add(element === commanderPreview ? 'preview-etched' : 'inspector-etched');
				}
			};

			const applyPreviewFinish = (card: SlotCard | null): void => {
				applyFoilClass(commanderPreview, card?.foil);
			};

			const applyInspectorFinish = (card: SlotCard | null): void => {
				applyFoilClass(commanderInspectorLeft, card?.foil);
			};

			const escapeHtml = (value: string): string => value
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')
				.replaceAll('"', '&quot;')
				.replaceAll("'", '&#39;');

			const manaClassFromSymbol = (symbol: string): string => {
				const normalized = symbol.trim().toUpperCase().replaceAll(' ', '');
				if (normalized === 'T') return 'tap';
				if (normalized === 'Q') return 'untap';

				return symbol
					.trim()
					.toLowerCase()
					.replaceAll('/', '')
					.replaceAll('½', 'half')
					.replaceAll('∞', 'infinity')
					.replaceAll(' ', '');
			};

			const manaCostToHtml = (manaCost: string): string => {
				const symbols = Array.from(manaCost.matchAll(/\{([^}]+)\}/g)).map((match) => match[1]);
				if (symbols.length === 0) return escapeHtml(manaCost);

				return symbols
					.map((symbol) => {
						const symbolClass = manaClassFromSymbol(symbol);
						return `<i class="ms ms-cost ms-${escapeHtml(symbolClass)}" title="${escapeHtml(`{${symbol}}`)}" aria-label="${escapeHtml(`{${symbol}}`)}"></i>`;
					})
					.join('');
			};

			const manaTextToHtml = (value: string): string => {
				const pattern = /\{([^}]+)\}/g;
				let html = '';
				let cursor = 0;
				let match = pattern.exec(value);

				while (match) {
					html += escapeHtml(value.slice(cursor, match.index));
					const symbol = match[1];
					const symbolClass = manaClassFromSymbol(symbol);
					html += `<i class="ms ms-cost ms-${escapeHtml(symbolClass)}" title="${escapeHtml(`{${symbol}}`)}" aria-label="${escapeHtml(`{${symbol}}`)}"></i>`;
					cursor = match.index + match[0].length;
					match = pattern.exec(value);
				}

				html += escapeHtml(value.slice(cursor));
				return html.replaceAll('\n', '<br />');
			};

			const langToFlag = (langCode: string | undefined): string => {
				switch (langCode) {
					case 'en': return '🇺🇸';
					case 'es': return '🇪🇸';
					case 'fr': return '🇫🇷';
					case 'de': return '🇩🇪';
					case 'it': return '🇮🇹';
					case 'pt': return '🇧🇷';
					case 'ja': return '🇯🇵';
					case 'ko': return '🇰🇷';
					case 'ru': return '🇷🇺';
					case 'zhs': return '🇨🇳';
					case 'zht': return '🇹🇼';
					default: return '❓';
				}
			};

			const buildOracleText = (card: ScryfallOracleCard): string => {
				if (card.oracle_text?.trim()) {
					const typeLine = card.type_line?.trim() ? `${card.type_line}\n\n` : '';
					return `${typeLine}${card.oracle_text.trim()}`;
				}

				if (card.card_faces && card.card_faces.length > 0) {
					const parts = card.card_faces
						.map((face) => {
							const line = face.type_line?.trim() ? `${face.type_line}\n` : '';
							const text = face.oracle_text?.trim() ?? '';
							return `${line}${text}`.trim();
						})
						.filter(Boolean);
					if (parts.length > 0) return parts.join('\n\n//\n\n');
				}

				return 'No oracle text available.';
			};

			const normalizeDeckName = (value: string | undefined): string => (value ?? '').trim().toLowerCase();

			const buildRows = async (cards: SlotCard[]): Promise<DeckRow[]> => {
				const grouped = new Map<string, { count: number; card: SlotCard }>();

				cards.forEach((card) => {
					const key = [card.id, card.lang ?? '', card.foil ?? 'nonfoil', card.setCode ?? '', card.collectorNumber ?? ''].join('|');
					const existing = grouped.get(key);
					if (existing) {
						existing.count += 1;
					} else {
						grouped.set(key, { count: 1, card });
					}
				});

				const rows: DeckRow[] = [];
				for (const entry of grouped.values()) {
					const key = [
						entry.card.id,
						entry.card.lang ?? '',
						entry.card.foil ?? 'nonfoil',
						entry.card.setCode ?? '',
						entry.card.collectorNumber ?? ''
					].join('|');
					const meta = await fetchMeta(entry.card);
					const priceInfo = formatPrice(meta, entry.card.foil);
					rows.push({
						key,
						count: entry.count,
						card: entry.card,
						meta,
						section: sectionFromType(meta.typeLine),
						price: priceInfo.numeric
					});
				}

				return rows;
			};

			let deckMap = new Map<string, SlotCard[]>();
			let activeDeckName = '';
			let activeDeckFormat: DeckFormat = 'custom';
			let currentRows: DeckRow[] = [];
			let deckFormatMap = readDeckFormats();
			let deckColorMap = readDeckColors();
			let deckCommanderMap = readDeckCommanders();
			let activeCommanderKey = '';
			let activeCommanderCard: SlotCard | null = null;
			let activeCommanderMeta: CardMeta | null = null;
			let editingDeckName = '';
			let isCreateMode = false;
			let renderDeckToken = 0;
			let commanderSearchToken = 0;
			let commanderSearchDebounceTimer: number | null = null;
			let commanderSearchResolve: ((value: SlotCard | null) => void) | null = null;
			let commanderSearchList: ScryfallSearchCard[] = [];
			let commanderSearchMode: 'commander' | 'deck-card' = 'commander';
			let deckSearchToken = 0;
			let deckSearchDebounceTimer: number | null = null;
			let deckSearchList: ScryfallSearchCard[] = [];
			let inspectorOracleToken = 0;
			const inspectorOracleCache = new Map<string, string>();
			let inspectorMode: 'commander' | 'deck-row' | null = null;
			let inspectedDeckRow: DeckRow | null = null;

			const openDeckEditor = (deckName: string): void => {
				isCreateMode = false;
				editingDeckName = deckName;
				deckEditorTitle.textContent = 'Edit Deck';
				saveDeckBtn.textContent = 'Save';
				editDeckNameInput.value = deckName;
				editDeckColorInput.value = deckColorMap[deckName] ?? '#2c3e50';
				editDeckFormatSelect.value = deckFormatMap[deckName] ?? 'custom';
				deckColorRow.hidden = false;
				deleteDeckBtn.hidden = false;
				deckEditorStatus.textContent = '';
				deckEditorBackdrop.hidden = false;
			};

			const openCreateDeckEditor = (): void => {
				isCreateMode = true;
				editingDeckName = '';
				deckEditorTitle.textContent = 'Create Deck';
				saveDeckBtn.textContent = 'Create Deck';
				editDeckNameInput.value = '';
				editDeckColorInput.value = '#2c3e50';
				editDeckFormatSelect.value = 'commander';
				deckColorRow.hidden = true;
				deleteDeckBtn.hidden = true;
				deckEditorStatus.textContent = '';
				deckEditorBackdrop.hidden = false;
			};

			const closeDeckEditor = (): void => {
				deckEditorBackdrop.hidden = true;
				editingDeckName = '';
				isCreateMode = false;
				deckEditorStatus.textContent = '';
			};

			const getCardsForDeck = (deckName: string): SlotCard[] => {
				const source = deckMap.get(deckName) ?? [];
				return [...source];
			};

			const renderStats = (rows: DeckRow[]): void => {
				const commanderIsExternal = !!(activeCommanderCard && !rows.some((row) => row.key === activeCommanderKey));
				const totalCards = rows.reduce((sum, row) => sum + row.count, 0) + (commanderIsExternal ? 1 : 0);
				const nonlandRows = rows.filter((row) => !row.meta.typeLine.includes('Land'));
				const commanderNonlandBonus = commanderIsExternal && activeCommanderMeta && !activeCommanderMeta.typeLine.includes('Land') ? 1 : 0;
				const nonlandCards = nonlandRows.reduce((sum, row) => sum + row.count, 0) + commanderNonlandBonus;
				const nonlandCmc = nonlandRows.reduce((sum, row) => sum + row.meta.cmc * row.count, 0);
				const avgMv = nonlandCards > 0 ? (nonlandCmc / nonlandCards) : 0;

				const commanderPriceBonus = commanderIsExternal && activeCommanderMeta && activeCommanderCard
					? formatPrice(activeCommanderMeta, activeCommanderCard.foil).numeric
					: 0;
				const totalPrice = rows.reduce((sum, row) => sum + row.price * row.count, 0) + commanderPriceBonus;

				if (activeDeckFormat === 'commander') {
					statCards.textContent = `${totalCards}/100`;
					sideboardStat.hidden = true;
				} else {
					statCards.textContent = String(totalCards);
					statSideboard.textContent = '0/15';
					sideboardStat.hidden = false;
				}
				statAvgMv.textContent = avgMv.toFixed(2);
				statNonlands.textContent = String(nonlandCards);
				statPrice.textContent = `EUR ${totalPrice.toFixed(2)}`;

				const colorTotals = new Map<string, number>();
				rows.forEach((row) => {
					const colors = row.meta.colorIdentity;
					if (colors.length === 0) return;
					colors.forEach((symbol) => {
						colorTotals.set(symbol, (colorTotals.get(symbol) ?? 0) + row.count);
					});
				});

				deckColors.innerHTML = '';
				['W', 'U', 'B', 'R', 'G'].forEach((symbol) => {
					const value = colorTotals.get(symbol) ?? 0;
					if (value === 0) return;
					const chip = document.createElement('span');
					chip.className = `color-chip color-${symbol}`;
					chip.title = `${colorLabel(symbol)} ${value}`;
					chip.setAttribute('aria-label', `${colorLabel(symbol)} ${value}`);
					chip.innerHTML = `<i class="ms ms-${symbol.toLowerCase()} ms-cost" aria-hidden="true"></i>`;
					deckColors.appendChild(chip);
				});
				if (deckColors.children.length === 0) {
					const chip = document.createElement('span');
					chip.className = 'color-chip';
					chip.title = 'Colorless';
					chip.setAttribute('aria-label', 'Colorless');
					chip.innerHTML = '<i class="ms ms-c ms-cost" aria-hidden="true"></i>';
					deckColors.appendChild(chip);
				}

				const curveBuckets = [0, 0, 0, 0, 0, 0, 0, 0];
				nonlandRows.forEach((row) => {
					const index = Math.min(7, Math.max(0, Math.floor(row.meta.cmc)));
					curveBuckets[index] += row.count;
				});
				const maxBucket = Math.max(1, ...curveBuckets);

				deckCurve.innerHTML = '';
				curveBuckets.forEach((value, index) => {
					const col = document.createElement('div');
					col.className = 'curve-col';

					const valueEl = document.createElement('div');
					valueEl.className = 'curve-num';
					valueEl.textContent = String(value);

					const bar = document.createElement('div');
					bar.className = 'curve-bar';
					bar.style.height = `${Math.max(2, Math.round((value / maxBucket) * 90))}px`;

					const label = document.createElement('div');
					label.className = 'curve-num';
					label.textContent = index === 7 ? '7+' : String(index);

					col.append(valueEl, bar, label);
					deckCurve.appendChild(col);
				});
			};

			const renderDeckRow = (row: DeckRow, quantityOverride?: number): HTMLButtonElement => {
				const imageUrl = row.card.imageUrlLarge || row.card.imageUrl || '/favicon.svg';
				const manaCost = row.meta.manaCost || '';
				const manaCostHtml = manaCostToHtml(manaCost);
				const manaValue = Number.isFinite(row.meta.cmc) ? row.meta.cmc : 0;
				const rowEl = document.createElement('button');
				rowEl.type = 'button';
				rowEl.className = 'deck-row' + (row.card.proxy ? ' is-proxy' : '');
				rowEl.title = row.card.name;
				rowEl.innerHTML = `
					<div class="deck-row-qty">${quantityOverride ?? row.count}</div>
					<div class="deck-row-name">${escapeHtml(row.card.name)}${row.card.proxy ? ' <span class="deck-row-proxy-badge">P</span>' : ''}</div>
					<div class="deck-row-cost">${manaCostHtml}</div>
				`;
				const nameEl = rowEl.querySelector('.deck-row-name') as HTMLDivElement | null;
				if (nameEl) {
					nameEl.addEventListener('mouseenter', () => {
						deckPreview.src = imageUrl;
						deckPreview.alt = row.card.name;
						applyPreviewFinish(row.card);
					});
				}
				if (!activeCommanderCard) {
					rowEl.addEventListener('mouseenter', () => {
						deckPreview.src = imageUrl;
						deckPreview.alt = row.card.name;
						applyPreviewFinish(row.card);
					});
				}
				rowEl.addEventListener('click', () => {
					void openDeckRowInspector(row);
				});
				return rowEl;
			};

			const syncCommanderPreviewState = (): void => {
				const isInteractive = activeDeckFormat === 'commander';
				const hasCommander = Boolean(activeCommanderCard);
				commanderPreview.disabled = !isInteractive;
				commanderPreview.classList.toggle('is-static', !isInteractive);
				commanderPreview.setAttribute('aria-label', hasCommander ? 'Open commander details' : 'Add commander');
				if (!hasCommander) {
					commanderInspectorBackdrop.hidden = true;
				}
			};

			const closeCommanderInspector = (): void => {
				inspectorMode = null;
				inspectedDeckRow = null;
				commanderInspectorBackdrop.hidden = true;
			};

			const getInspectedCard = (): SlotCard | null => {
				if (inspectorMode === 'commander') return activeCommanderCard;
				if (inspectorMode === 'deck-row') return inspectedDeckRow?.card ?? null;
				return null;
			};

			const getInspectedMeta = (): CardMeta | null => {
				if (inspectorMode === 'commander') return activeCommanderMeta;
				if (inspectorMode === 'deck-row') return inspectedDeckRow?.meta ?? null;
				return null;
			};

			const getInspectedCollectionSource = (): string | null => {
				const deckSource = activeDeckName.trim();
				if (!deckSource) return null;
				if (inspectorMode === 'commander' || inspectorMode === 'deck-row') {
					return `deck:${deckSource.toLowerCase()}`;
				}
				return null;
			};

			const loadInspectorOracleText = async (cardId: string): Promise<void> => {
				const token = ++inspectorOracleToken;

				const applyIfCurrent = (text: string): void => {
					const current = getInspectedCard();
					if (!current || current.id !== cardId || token !== inspectorOracleToken) return;
					commanderInspectorErrata.innerHTML = manaTextToHtml(text);
				};

				const cached = inspectorOracleCache.get(cardId);
				if (cached) {
					applyIfCurrent(cached);
					return;
				}

				try {
					const response = await fetch(`https://api.scryfall.com/cards/${encodeURIComponent(cardId)}`);
					if (!response.ok) {
						applyIfCurrent(`Failed to load oracle text (HTTP ${response.status}).`);
						return;
					}

					const payload = await response.json() as ScryfallOracleCard;
					const text = buildOracleText(payload);
					inspectorOracleCache.set(cardId, text);
					applyIfCurrent(text);
				} catch {
					applyIfCurrent('Network error while loading oracle text.');
				}
			};

			const renderCommanderInspector = (): void => {
				const card = getInspectedCard();
				const meta = getInspectedMeta();
				if (!card) return;

				const image = card.imageUrlLarge || card.imageUrl || '/favicon.svg';
				const langFlag = langToFlag(card.lang);
				const metaParts = [
					card.setName,
					card.collectorNumber ? `#${card.collectorNumber}` : '',
					langFlag,
					card.foil === 'foil' ? 'Foil' : card.foil === 'etched' ? 'Etched' : 'Nonfoil'
				].filter((part) => Boolean(part));

				commanderInspectorImage.src = image;
				commanderInspectorImage.alt = card.name;
				applyInspectorFinish(card);
				commanderInspectorTitle.textContent = card.name;
				commanderInspectorMeta.textContent = metaParts.join(' · ');
				commanderInspectorPrice.textContent = meta ? formatPrice(meta, card.foil).text : '-';
				commanderInspectorErrata.textContent = 'Loading oracle text...';
				void loadInspectorOracleText(card.id);
				changeCommanderBtn.textContent = 'Select Version';
				removeCommanderBtn.textContent = inspectorMode === 'commander' ? 'Remove Commander' : 'Remove';
				commanderInspectorFoilSelect.value = card.foil ?? 'nonfoil';
				commanderInspectorLangSelect.value = card.lang ?? 'en';
				proxyToggleBtn.classList.toggle('is-proxy', card.proxy === true);
				proxyToggleBtn.textContent = card.proxy ? 'Proxy ✓' : 'Proxy';
				syncAddToCollectionButton(card);
			};

			const openCommanderInspector = (): void => {
				inspectorMode = 'commander';
				inspectedDeckRow = null;
				if (!activeCommanderCard) return;
				renderCommanderInspector();
				commanderInspectorBackdrop.hidden = false;
			};

			const openDeckRowInspector = async (row: DeckRow): Promise<void> => {
				inspectorMode = 'deck-row';
				inspectedDeckRow = row;
				renderCommanderInspector();
				commanderInspectorBackdrop.hidden = false;
			};

			const refreshDeckRowInspector = (): void => {
				if (inspectorMode !== 'deck-row' || !inspectedDeckRow) return;
				const nextRow = currentRows.find((row) => row.key === inspectedDeckRow?.key);
				if (!nextRow) {
					closeCommanderInspector();
					return;
				}
				inspectedDeckRow = nextRow;
				renderCommanderInspector();
			};

			const removeInspectedDeckRow = async (): Promise<void> => {
				if (!activeDeckName || !inspectedDeckRow) return;
				const rowKey = inspectedDeckRow.key;
				const cards = (deckMap.get(activeDeckName) ?? []).filter((card) => rowKeyFromCard(card) !== rowKey);
				deckMap.set(activeDeckName, cards);
				saveDeckMap();
				// Also remove from collection
				const collectionCards = readCollectionCards();
				const cardId = inspectedDeckRow.card.id;
				const updatedCollection = collectionCards.filter((c) => c.id !== cardId);
				saveCollectionCards(updatedCollection);
				closeCommanderInspector();
				await renderDeck();
			};

			const updateInspectedCard = async (updates: Partial<SlotCard>): Promise<void> => {
				if (!activeDeckName) return;

				if (inspectorMode === 'commander' && activeCommanderCard) {
					const nextCommander = { ...activeCommanderCard, ...updates };
					await setCommander(nextCommander);
					renderCommanderInspector();
					return;
				}

				if (inspectorMode === 'deck-row' && inspectedDeckRow) {
					const previousRow = inspectedDeckRow;
					const updatedKey = rowKeyFromCard({ ...previousRow.card, ...updates });
					const cards = [...(deckMap.get(activeDeckName) ?? [])];
					let changed = false;
					const nextCards = cards.map((card) => {
						if (rowKeyFromCard(card) !== previousRow.key) return card;
						changed = true;
						return { ...card, ...updates };
					});

					if (!changed) return;

					deckMap.set(activeDeckName, nextCards);
					saveDeckMap();
					await renderDeck();
					const nextRow = currentRows.find((row) => row.key === updatedKey);
					if (!nextRow) {
						closeCommanderInspector();
						return;
					}
					inspectedDeckRow = nextRow;
					renderCommanderInspector();
				}
			};

			const commanderSearchBaseTitle = (): string => {
				return commanderSearchMode === 'deck-card' ? 'Search Cards' : 'Search Commander';
			};

			const asSlotCard = (card: ScryfallSearchCard): SlotCard => {
				return {
					id: card.id,
					name: card.name,
					imageUrl: pickCardImageSmall(card),
					imageUrlLarge: pickCardImageNormal(card),
					scryfallUri: card.scryfall_uri,
					setCode: card.set,
					setName: card.set_name,
					collectorNumber: card.collector_number,
					lang: card.lang,
					foil: 'nonfoil'
				};
			};

			const resolveCommanderSearch = (selected: SlotCard | null): void => {
				if (!commanderSearchResolve) return;
				const resolve = commanderSearchResolve;
				commanderSearchResolve = null;
				resolve(selected);
			};

			const closeCommanderSearchModal = (selected: SlotCard | null = null): void => {
				if (commanderSearchDebounceTimer !== null) {
					window.clearTimeout(commanderSearchDebounceTimer);
					commanderSearchDebounceTimer = null;
				}
				commanderSearchBackdrop.hidden = true;
				commanderSearchTitle.textContent = commanderSearchBaseTitle();
				commanderSearchBackBtn.hidden = true;
				commanderSearchInput.hidden = false;
				commanderSearchInput.disabled = false;
				commanderSearchInput.value = '';
				commanderSearchStatus.textContent = 'Type at least 2 characters to search.';
				commanderSearchResults.innerHTML = '';
				commanderSearchList = [];
				resolveCommanderSearch(selected);
			};

			const openCommanderVersionDialog = (cardName: string): Promise<SlotCard | null> => {
				closeCommanderInspector();
				commanderSearchBackdrop.hidden = false;
				commanderSearchTitle.textContent = `Select Version: ${cardName}`;
				commanderSearchBackBtn.hidden = true;
				commanderSearchInput.hidden = true;
				commanderSearchInput.disabled = true;
				commanderSearchInput.value = '';
				commanderSearchResults.innerHTML = '';
				commanderSearchList = [];
				commanderSearchStatus.textContent = `Loading printings for ${cardName}...`;

				const printsUrl = `https://api.scryfall.com/cards/search?q=${encodeURIComponent('!"' + cardName + '"')}&unique=prints&order=released&dir=desc`;

				void fetch(printsUrl, {
					headers: {
						'Accept': 'application/json;q=0.9,*/*;q=0.8'
					}
				})
					.then(async (response) => {
						if (!response.ok) {
							commanderSearchStatus.textContent = `Failed to load versions (HTTP ${response.status}).`;
							commanderSearchResults.innerHTML = '';
							return;
						}
						const payload = await response.json() as { data?: ScryfallSearchCard[] };
						const versions = (payload.data ?? [])
							.filter((item) => !item.digital)
							.filter((item) => Boolean(pickCardImageSmall(item)))
							.slice(0, 60);

						commanderSearchStatus.textContent = versions.length > 0
							? `Select printing for ${cardName}`
							: `No printable versions found for ${cardName}.`;
						renderCommanderVersionCards(versions);
					})
					.catch(() => {
						commanderSearchStatus.textContent = `Network error while loading versions for ${cardName}.`;
						commanderSearchResults.innerHTML = '';
					});

				return new Promise((resolve) => {
					commanderSearchResolve = resolve;
				});
			};

			const closeDeckSearchPanel = (): void => {
				if (deckSearchDebounceTimer !== null) {
					window.clearTimeout(deckSearchDebounceTimer);
					deckSearchDebounceTimer = null;
				}
				deckSearchPanel.hidden = true;
				deckSearchTitle.textContent = 'Search Cards';
				deckSearchBackBtn.hidden = true;
				deckSearchStatus.textContent = 'Type at least 2 characters to search.';
				deckSearchResults.innerHTML = '';
				deckSearchList = [];
			};

			const renderDeckSearchCards = (cards: ScryfallSearchCard[]): void => {
				deckSearchResults.innerHTML = '';
				cards.forEach((card) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'commander-result';

					const img = document.createElement('img');
					img.src = pickCardImageSmall(card) ?? '/favicon.svg';
					img.alt = card.name;
					img.loading = 'lazy';

					const textWrap = document.createElement('div');
					const name = document.createElement('div');
					name.className = 'commander-result-name';
					name.textContent = card.name;

					const setLine = document.createElement('div');
					setLine.className = 'commander-result-sub';
					const setCode = (card.set ?? '').toUpperCase();
					const collector = card.collector_number ?? '?';
					setLine.textContent = `${card.set_name ?? 'Unknown Set'} (${setCode}) #${collector}`;

					textWrap.append(name, setLine);
					button.append(img, textWrap);

					button.addEventListener('click', () => {
						void openDeckVersionPicker(card);
					});
					deckSearchResults.appendChild(button);
				});
			};

			const renderDeckVersionCards = (cards: ScryfallSearchCard[]): void => {
				deckSearchResults.innerHTML = '';
				cards.forEach((card) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'commander-result';

					const img = document.createElement('img');
					img.src = pickCardImageSmall(card) ?? '/favicon.svg';
					img.alt = card.name;
					img.loading = 'eager';

					const textWrap = document.createElement('div');
					const name = document.createElement('div');
					name.className = 'commander-result-name';
					name.textContent = card.name;

					const setLine = document.createElement('div');
					setLine.className = 'commander-result-sub';
					const setCode = (card.set ?? '').toUpperCase();
					const collector = card.collector_number ?? '?';
					const langFlag = langToFlag(card.lang ?? 'en');
					setLine.textContent = `${card.set_name ?? 'Unknown Set'} (${setCode}) #${collector} · ${langFlag}`;

					textWrap.append(name, setLine);
					button.append(img, textWrap);

					button.addEventListener('click', () => {
						closeCommanderSearchModal(asSlotCard(card));
					});
					deckSearchResults.appendChild(button);
				});
			};

			const openDeckVersionPicker = async (card: ScryfallSearchCard): Promise<void> => {
				deckSearchTitle.textContent = `Select Version: ${card.name}`;
				deckSearchBackBtn.hidden = false;
				deckSearchStatus.textContent = `Loading printings for ${card.name}...`;
				deckSearchResults.innerHTML = '';

				const printsUrl = card.prints_search_uri
					? `${card.prints_search_uri}${card.prints_search_uri.includes('?') ? '&' : '?'}order=released&dir=desc`
					: `https://api.scryfall.com/cards/search?q=${encodeURIComponent('!"' + card.name + '"')}&unique=prints&order=released&dir=desc`;

				try {
					const response = await fetch(printsUrl, {
						headers: {
							'Accept': 'application/json;q=0.9,*/*;q=0.8'
						}
					});

					if (!response.ok) {
						deckSearchStatus.textContent = `Failed to load versions (HTTP ${response.status}).`;
						return;
					}

					const payload = await response.json() as { data?: ScryfallSearchCard[] };
					const versions = (payload.data ?? [])
						.filter((item) => !item.digital)
						.filter((item) => Boolean(pickCardImageSmall(item)))
						.slice(0, 60);

					deckSearchStatus.textContent = versions.length > 0
						? `Select printing for ${card.name}`
						: `No printable versions found for ${card.name}.`;

					renderDeckVersionCards(versions);
				} catch {
					deckSearchStatus.textContent = `Network error while loading versions for ${card.name}.`;
				}
			};

			const restoreDeckSearchList = (): void => {
				deckSearchTitle.textContent = 'Search Cards';
				deckSearchBackBtn.hidden = true;
				if (deckSearchList.length > 0) {
					deckSearchStatus.textContent = `Found ${deckSearchList.length} result${deckSearchList.length === 1 ? '' : 's'}. Click one to choose version.`;
					renderDeckSearchCards(deckSearchList);
				} else {
					deckSearchStatus.textContent = 'Type at least 2 characters to search.';
					deckSearchResults.innerHTML = '';
				}
			};

			const searchDeckCardList = async (query: string): Promise<void> => {
				const trimmed = query.trim();
				if (trimmed.length < 2) {
					deckSearchStatus.textContent = 'Type at least 2 characters to search.';
					deckSearchResults.innerHTML = '';
					deckSearchList = [];
					return;
				}

				const currentToken = ++deckSearchToken;
				deckSearchStatus.textContent = 'Searching Scryfall...';

				try {
					const queryValue = `name:/${escapeScryfallRegex(trimmed)}/`;
					const response = await fetch(`https://api.scryfall.com/cards/search?q=${encodeURIComponent(queryValue)}&unique=cards&order=name`, {
						headers: {
							'Accept': 'application/json;q=0.9,*/*;q=0.8'
						}
					});

					if (currentToken !== deckSearchToken) return;

					if (!response.ok) {
						if (response.status === 404) {
							deckSearchStatus.textContent = 'No cards found.';
							deckSearchResults.innerHTML = '';
							deckSearchList = [];
							return;
						}
						deckSearchStatus.textContent = `Search failed (HTTP ${response.status}).`;
						deckSearchResults.innerHTML = '';
						deckSearchList = [];
						return;
					}

					const payload = await response.json() as { data?: ScryfallSearchCard[] };
					const needle = trimmed.toLowerCase();
					const cards = (payload.data ?? [])
						.filter((card) => (card.name ?? '').toLowerCase().includes(needle))
						.filter((card) => !card.digital)
						.filter((card) => Boolean(pickCardImageSmall(card)))
						.slice(0, 24);

					deckSearchList = cards;
					deckSearchTitle.textContent = 'Search Cards';
					deckSearchBackBtn.hidden = true;
					deckSearchStatus.textContent = cards.length > 0
						? `Found ${cards.length} result${cards.length === 1 ? '' : 's'}. Click one to choose version.`
						: 'No cards found.';
					renderDeckSearchCards(cards);
				} catch {
					if (currentToken !== deckSearchToken) return;
					deckSearchList = [];
					deckSearchStatus.textContent = 'Network error while searching Scryfall.';
					deckSearchResults.innerHTML = '';
				}
			};

			const openDeckSearchPanel = (initialValue = ''): void => {
				deckSearchPanel.hidden = false;
				deckSearchTitle.textContent = 'Search Cards';
				deckSearchBackBtn.hidden = true;
				deckSearchResults.innerHTML = '';
				deckSearchList = [];
				const trimmed = initialValue.trim();
				deckSearchStatus.textContent = trimmed.length >= 2 ? 'Searching Scryfall...' : 'Type at least 2 characters to search.';
			};

			const renderCommanderSearchCards = (cards: ScryfallSearchCard[]): void => {
				commanderSearchResults.innerHTML = '';
				cards.forEach((card) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'commander-result';

					const img = document.createElement('img');
					img.src = pickCardImageSmall(card) ?? '/favicon.svg';
					img.alt = card.name;
					img.loading = 'lazy';

					const textWrap = document.createElement('div');
					const name = document.createElement('div');
					name.className = 'commander-result-name';
					name.textContent = card.name;

					const setLine = document.createElement('div');
					setLine.className = 'commander-result-sub';
					const setCode = (card.set ?? '').toUpperCase();
					const collector = card.collector_number ?? '?';
					setLine.textContent = `${card.set_name ?? 'Unknown Set'} (${setCode}) #${collector}`;

					textWrap.append(name, setLine);
					button.append(img, textWrap);

					button.addEventListener('click', () => {
						void openCommanderVersionPicker(card);
					});
					commanderSearchResults.appendChild(button);
				});
			};

			const renderCommanderVersionCards = (cards: ScryfallSearchCard[]): void => {
				commanderSearchResults.innerHTML = '';
				cards.forEach((card) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'commander-result';

					const img = document.createElement('img');
					img.src = pickCardImageSmall(card) ?? '/favicon.svg';
					img.alt = card.name;
					img.loading = 'eager';

					const textWrap = document.createElement('div');
					const name = document.createElement('div');
					name.className = 'commander-result-name';
					name.textContent = card.name;

					const setLine = document.createElement('div');
					setLine.className = 'commander-result-sub';
					const setCode = (card.set ?? '').toUpperCase();
					const collector = card.collector_number ?? '?';
					const langFlag = langToFlag(card.lang ?? 'en');
					setLine.textContent = `${card.set_name ?? 'Unknown Set'} (${setCode}) #${collector} · ${langFlag}`;

					textWrap.append(name, setLine);
					button.append(img, textWrap);

					button.addEventListener('click', () => {
						closeCommanderSearchModal(asSlotCard(card));
					});
					commanderSearchResults.appendChild(button);
				});
			};

			const openCommanderVersionPicker = async (card: ScryfallSearchCard): Promise<void> => {
				commanderSearchTitle.textContent = `Select Version: ${card.name}`;
				commanderSearchBackBtn.hidden = false;
				commanderSearchInput.disabled = true;
				commanderSearchStatus.textContent = `Loading printings for ${card.name}...`;
				commanderSearchResults.innerHTML = '';

				const printsUrl = card.prints_search_uri
					? `${card.prints_search_uri}${card.prints_search_uri.includes('?') ? '&' : '?'}order=released&dir=desc`
					: `https://api.scryfall.com/cards/search?q=${encodeURIComponent('!"' + card.name + '"')}&unique=prints&order=released&dir=desc`;

				try {
					const response = await fetch(printsUrl, {
						headers: {
							'Accept': 'application/json;q=0.9,*/*;q=0.8'
						}
					});

					if (!response.ok) {
						commanderSearchStatus.textContent = `Failed to load versions (HTTP ${response.status}).`;
						return;
					}

					const payload = await response.json() as { data?: ScryfallSearchCard[] };
					const versions = (payload.data ?? [])
						.filter((item) => !item.digital)
						.filter((item) => Boolean(pickCardImageSmall(item)))
						.slice(0, 60);

					commanderSearchStatus.textContent = versions.length > 0
						? `Select printing for ${card.name}`
						: `No printable versions found for ${card.name}.`;

					renderCommanderVersionCards(versions);
				} catch {
					commanderSearchStatus.textContent = `Network error while loading versions for ${card.name}.`;
				}
			};

			const restoreCommanderSearchList = (): void => {
				commanderSearchTitle.textContent = commanderSearchBaseTitle();
				commanderSearchBackBtn.hidden = true;
				commanderSearchInput.disabled = false;
				commanderSearchInput.focus();
				if (commanderSearchList.length > 0) {
					commanderSearchStatus.textContent = `Found ${commanderSearchList.length} result${commanderSearchList.length === 1 ? '' : 's'}. Click one to choose version.`;
					renderCommanderSearchCards(commanderSearchList);
				} else {
					commanderSearchStatus.textContent = 'Type at least 2 characters to search.';
					commanderSearchResults.innerHTML = '';
				}
			};

			const searchCommanderList = async (query: string): Promise<void> => {
				const trimmed = query.trim();
				if (trimmed.length < 2) {
					commanderSearchStatus.textContent = 'Type at least 2 characters to search.';
					commanderSearchResults.innerHTML = '';
					commanderSearchList = [];
					return;
				}

				const currentToken = ++commanderSearchToken;
				commanderSearchStatus.textContent = 'Searching Scryfall...';

				try {
					const queryValue = `name:/${escapeScryfallRegex(trimmed)}/`;
					const response = await fetch(`https://api.scryfall.com/cards/search?q=${encodeURIComponent(queryValue)}&unique=cards&order=name`, {
						headers: {
							'Accept': 'application/json;q=0.9,*/*;q=0.8'
						}
					});

					if (currentToken !== commanderSearchToken) return;

					if (!response.ok) {
						if (response.status === 404) {
							commanderSearchStatus.textContent = 'No cards found.';
							commanderSearchResults.innerHTML = '';
							commanderSearchList = [];
							return;
						}
						commanderSearchStatus.textContent = `Search failed (HTTP ${response.status}).`;
						commanderSearchResults.innerHTML = '';
						commanderSearchList = [];
						return;
					}

					const payload = await response.json() as { data?: ScryfallSearchCard[] };
					const needle = trimmed.toLowerCase();
					const cards = (payload.data ?? [])
						.filter((card) => (card.name ?? '').toLowerCase().includes(needle))
						.filter((card) => !card.digital)
						.filter((card) => Boolean(pickCardImageSmall(card)))
						.slice(0, 24);

					commanderSearchList = cards;
					commanderSearchTitle.textContent = 'Search Commander';
					commanderSearchBackBtn.hidden = true;
					commanderSearchInput.disabled = false;
					commanderSearchStatus.textContent = cards.length > 0
						? `Found ${cards.length} result${cards.length === 1 ? '' : 's'}. Click one to choose version.`
						: 'No cards found.';
					renderCommanderSearchCards(cards);
				} catch {
					if (currentToken !== commanderSearchToken) return;
					commanderSearchList = [];
					commanderSearchStatus.textContent = 'Network error while searching Scryfall.';
					commanderSearchResults.innerHTML = '';
				}
			};

			const openCommanderSearchDialog = (initialValue = '', mode: 'commander' | 'deck-card' = 'commander'): Promise<SlotCard | null> => {
				closeCommanderInspector();
				commanderSearchMode = mode;
				commanderSearchBackdrop.hidden = false;
				commanderSearchTitle.textContent = commanderSearchBaseTitle();
				commanderSearchBackBtn.hidden = true;
				commanderSearchInput.disabled = false;
				commanderSearchInput.value = initialValue;
				commanderSearchResults.innerHTML = '';
				commanderSearchList = [];

				const trimmed = initialValue.trim();
				if (trimmed.length >= 2) {
					void searchCommanderList(trimmed);
				} else {
					commanderSearchStatus.textContent = 'Type at least 2 characters to search.';
				}

				window.setTimeout(() => commanderSearchInput.focus(), 0);

				return new Promise((resolve) => {
					commanderSearchResolve = resolve;
				});
			};

			const addCardToActiveDeck = async (selected: SlotCard): Promise<void> => {
				if (!activeDeckName) return;

				const cards = [...(deckMap.get(activeDeckName) ?? [])];
				cards.push({
					...selected,
					deckName: activeDeckName,
					inDeck: true
				});

				deckMap.set(activeDeckName, cards);
				saveDeckMap();
				await renderDeck();
			};

			const setCommander = async (selected: SlotCard): Promise<void> => {
				if (!activeDeckName) return;
				deckCommanderMap[activeDeckName] = selected;
				saveDeckCommanders(deckCommanderMap);
				activeCommanderCard = selected;
				activeCommanderMeta = await fetchMeta(selected);
				activeCommanderKey = rowKeyFromCard(selected);
				deckPreview.src = selected.imageUrlLarge || selected.imageUrl || '/favicon.svg';
				deckPreview.alt = selected.name;
				applyPreviewFinish(selected);
				renderCommanderInspector();
				renderRows();
			};

			const clearCommander = (): void => {
				if (!activeDeckName) return;
				delete deckCommanderMap[activeDeckName];
				saveDeckCommanders(deckCommanderMap);
				activeCommanderCard = null;
				activeCommanderMeta = null;
				activeCommanderKey = '';
				closeCommanderInspector();
				if (currentRows[0]) {
					deckPreview.src = currentRows[0].card.imageUrlLarge || currentRows[0].card.imageUrl || '/favicon.svg';
					deckPreview.alt = currentRows[0].card.name;
					applyPreviewFinish(currentRows[0].card);
				} else {
					deckPreview.src = '/favicon.svg';
					deckPreview.alt = 'Card preview';
					applyPreviewFinish(null);
				}
				renderRows();
			};

			const renderRows = (): void => {
				const sorted = [...currentRows];
				const commanderRow = activeCommanderKey ? (currentRows.find((row) => row.key === activeCommanderKey) ?? null) : null;
				const commanderDisplayRow = activeCommanderCard
					? (
						commanderRow
							? { ...commanderRow, count: 1, section: 'Commander' }
							: (activeCommanderMeta
								? {
									key: activeCommanderKey,
									count: 1,
									card: activeCommanderCard,
									meta: activeCommanderMeta,
									section: 'Commander',
									price: formatPrice(activeCommanderMeta, activeCommanderCard.foil).numeric
								}
								: null)
					)
					: null;

				deckSections.innerHTML = '';
				const sectionOrder = ['Creatures', 'Instants', 'Sorceries', 'Enchantments', 'Artifacts', 'Planeswalkers', 'Battles', 'Lands', 'Other'];
				const grouped = new Map<string, DeckRow[]>();
				sectionOrder.forEach((name) => grouped.set(name, []));
				sorted.forEach((row) => {
					if (commanderRow && row.key === commanderRow.key) return;
					const section = grouped.get(row.section) ?? grouped.get('Other');
					if (section) section.push(row);
				});

				let shownCards = 0;

				if (commanderDisplayRow) {
					const section = document.createElement('section');
					section.className = 'deck-section';

					const head = document.createElement('div');
					head.className = 'deck-section-head';
					head.innerHTML = `<span class="deck-section-name">Commander</span><span class="deck-section-count">1</span>`;
					section.appendChild(head);

					const cardGrid = document.createElement('div');
					cardGrid.className = 'deck-card-grid';
					cardGrid.appendChild(renderDeckRow(commanderDisplayRow, 1));
					section.appendChild(cardGrid);

					deckSections.appendChild(section);
					shownCards += 1;
				}

				sectionOrder.forEach((sectionName) => {
					const rows = grouped.get(sectionName) ?? [];
					if (rows.length === 0) return;

					const total = rows.reduce((sum, row) => sum + row.count, 0);
					shownCards += total;

					const section = document.createElement('section');
					section.className = 'deck-section';

					const head = document.createElement('div');
					head.className = 'deck-section-head';
					head.innerHTML = `<span class="deck-section-name">${escapeHtml(sectionName)}</span><span class="deck-section-count">${total}</span>`;
					section.appendChild(head);

					const cardGrid = document.createElement('div');
					cardGrid.className = 'deck-card-grid';

					rows.forEach((row) => {
						cardGrid.appendChild(renderDeckRow(row));
					});
					section.appendChild(cardGrid);

					deckSections.appendChild(section);
				});

				if (shownCards === 0) {
					deckSections.innerHTML = '';
				}

				renderStats(currentRows);
				refreshDeckRowInspector();


				syncCommanderPreviewState();
			};

			const renderDeck = async (): Promise<void> => {
				const token = ++renderDeckToken;
				const targetDeck = activeDeckName;
				const cards = getCardsForDeck(targetDeck);
				deckDetailTitle.textContent = activeDeckName || 'Deck';
				closeDeckSearchPanel();
				activeDeckFormat = deckFormatMap[activeDeckName] ?? 'custom';
				deckDetailFormat.textContent = formatLabel(activeDeckFormat);
				activeCommanderCard = deckCommanderMap[activeDeckName] ?? null;
				activeCommanderMeta = activeCommanderCard ? await fetchMeta(activeCommanderCard) : null;
				activeCommanderKey = activeCommanderCard ? rowKeyFromCard(activeCommanderCard) : '';
				syncCommanderPreviewState();
				currentRows = [];

				if (cards.length === 0) {
					currentRows = [];
					if (activeCommanderCard && activeCommanderMeta) {
						deckLayout.hidden = false;
						deckPreview.src = activeCommanderCard.imageUrlLarge || activeCommanderCard.imageUrl || '/favicon.svg';
						deckPreview.alt = activeCommanderCard.name;
						applyPreviewFinish(activeCommanderCard);
						renderRows();
						return;
					}

					deckLayout.hidden = false;
					deckPreview.src = '/favicon.svg';
					deckPreview.alt = 'Card preview';
					applyPreviewFinish(null);
					renderRows();
					return;
				}

				deckLayout.hidden = false;

				const builtRows = await buildRows(cards);
				if (token !== renderDeckToken || targetDeck !== activeDeckName) {
					return;
				}
				currentRows = builtRows;
				if (activeCommanderCard) {
					deckPreview.src = activeCommanderCard.imageUrlLarge || activeCommanderCard.imageUrl || '/favicon.svg';
					deckPreview.alt = activeCommanderCard.name;
					applyPreviewFinish(activeCommanderCard);
				} else {
					const first = currentRows[0];
					if (first) {
						deckPreview.src = first.card.imageUrlLarge || first.card.imageUrl || '/favicon.svg';
						deckPreview.alt = first.card.name;
						applyPreviewFinish(first.card);
					} else {
						applyPreviewFinish(null);
					}
				}

				renderRows();
			};

			const renderDeckHome = (): void => {
				const names = readDeckNames().filter((name) => deckMap.has(name));
				const existingCards = Array.from(deckGrid.querySelectorAll('.deck-card.select-deck-card'));
				existingCards.forEach((card) => card.remove());

				names.forEach((name, index) => {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'deck-card select-deck-card';
					button.style.background = deckColorMap[name] ?? '#2c3e50';
					button.dataset.deckName = name;

					if ((window as any).mtgIsAuthed) {
						button.draggable = true;
						button.addEventListener('dragstart', (event) => {
						draggedDeckName = name;
						button.classList.add('is-dragging');
						if (event.dataTransfer) {
							event.dataTransfer.effectAllowed = 'move';
							event.dataTransfer.setData('text/plain', name);
						}
					});
					button.addEventListener('dragend', () => {
						draggedDeckName = '';
						button.classList.remove('is-dragging');
						button.classList.remove('is-drop-target');
					});
					button.addEventListener('dragover', (event) => {
						if (!draggedDeckName || draggedDeckName === name) return;
						event.preventDefault();
						button.classList.add('is-drop-target');
						if (event.dataTransfer) {
							event.dataTransfer.dropEffect = 'move';
						}
					});
					button.addEventListener('dragleave', () => {
						button.classList.remove('is-drop-target');
					});
					button.addEventListener('drop', (event) => {
							event.preventDefault();
							button.classList.remove('is-drop-target');
							if (!draggedDeckName || draggedDeckName === name) return;
							moveDeckToTarget(draggedDeckName, name);
						});
					}

					const format = deckFormatMap[name] ?? 'custom';
					const colorSymbols = deckIdentitySymbols(name);
					const symbolsToRender = colorSymbols.length > 0 ? colorSymbols : ['C'];
					const colorHtml = symbolsToRender
						.map((symbol) => `<i class="ms ms-${symbol.toLowerCase()} ms-cost" aria-hidden="true"></i>`)
						.join('');
					button.innerHTML = `
						<p class="deck-card-format">${escapeHtml(formatLabel(format))}</p>
						<h3 class="deck-card-name">${escapeHtml(name)}</h3>
						<div class="deck-card-colors" aria-label="Deck colors">${colorHtml}</div>
					`;

					button.addEventListener('click', () => {
						activeDeckName = name;
						activeDeckFormat = deckFormatMap[name] ?? 'custom';
						deckHomeView.hidden = true;
						deckDetailView.hidden = false;
						void renderDeck();
					});

					if ((window as any).mtgIsAuthed) {
						const editBtn = document.createElement('button');
						editBtn.type = 'button';
						editBtn.className = 'deck-edit-btn';
						editBtn.textContent = 'Edit';
						editBtn.addEventListener('click', (event) => {
							event.stopPropagation();
							openDeckEditor(name);
						});
						button.appendChild(editBtn);
					}

					deckGrid.appendChild(button);
				});
			};

			const init = (): void => {
				deckMap = readDeckMap();
				deckFormatMap = readDeckFormats();
				deckColorMap = readDeckColors();
				deckCommanderMap = readDeckCommanders();

				const savedDeckNames = readDeckNames();
				const detectedDeckNames = Array.from(deckMap.keys());
				const mergedDeckNames = [...savedDeckNames];
				detectedDeckNames.forEach((deckName) => {
					if (!mergedDeckNames.includes(deckName)) {
						mergedDeckNames.push(deckName);
					}
				});

				mergedDeckNames.forEach((deckName) => {
					if (!deckMap.has(deckName)) {
						deckMap.set(deckName, []);
					}
					if (!deckFormatMap[deckName]) {
						deckFormatMap[deckName] = 'custom';
					}
					if (!deckColorMap[deckName]) {
						deckColorMap[deckName] = '#2c3e50';
					}
				});

				if (mergedDeckNames.length !== savedDeckNames.length || mergedDeckNames.some((name, index) => name !== savedDeckNames[index])) {
					saveDeckNames(mergedDeckNames);
				}
				saveDeckMap();
				saveDeckFormats(deckFormatMap);
				saveDeckColors(deckColorMap);

				renderDeckHome();

				const params = new URLSearchParams(window.location.search);
				const requestedDeck = (params.get('name') ?? '').trim();
				if (requestedDeck && deckMap.has(requestedDeck)) {
					activeDeckName = requestedDeck;
					deckHomeView.hidden = true;
					deckDetailView.hidden = false;
					void renderDeck();
				} else {
					deckHomeView.hidden = false;
					deckDetailView.hidden = true;
				}
			};

			openDeckBtn.addEventListener('click', () => {
				openCreateDeckEditor();
			});

			commanderPreview.addEventListener('click', async () => {
				if (!activeDeckName || activeDeckFormat !== 'commander') return;
				if (!activeCommanderCard) {
					if (!(window as any).mtgIsAuthed) return;
					const selected = await openCommanderSearchDialog('', 'commander');
					if (!selected) return;
					await setCommander(selected);
					return;
				}
				openCommanderInspector();
			});

			changeCommanderBtn.addEventListener('click', async (event) => {
				event.stopPropagation();
				const inspectedCard = getInspectedCard();
				if (!inspectedCard) return;
				const mode = inspectorMode === 'commander' ? 'commander' : 'deck-card';
				const selected = await openCommanderVersionDialog(inspectedCard.name);
				if (!selected) return;
				if (selected.name.trim().toLowerCase() !== inspectedCard.name.trim().toLowerCase()) {
					window.alert('Choose another printing of the same card.');
					if (mode === 'commander') {
						openCommanderInspector();
					} else if (inspectedDeckRow) {
						inspectorMode = 'deck-row';
						commanderInspectorBackdrop.hidden = false;
						renderCommanderInspector();
					}
					return;
				}
				if (mode === 'commander') {
					await setCommander({
						...selected,
						foil: activeCommanderCard?.foil ?? selected.foil,
						lang: selected.lang ?? activeCommanderCard?.lang
					});
					openCommanderInspector();
				} else {
					inspectorMode = 'deck-row';
					await updateInspectedCard({
						id: selected.id,
						name: selected.name,
						imageUrl: selected.imageUrl,
						imageUrlLarge: selected.imageUrlLarge,
						scryfallUri: selected.scryfallUri,
						setCode: selected.setCode,
						setName: selected.setName,
						collectorNumber: selected.collectorNumber,
						lang: selected.lang ?? inspectedCard.lang
					});
					if (inspectedDeckRow) {
						commanderInspectorBackdrop.hidden = false;
						renderCommanderInspector();
					}
				}
			});

			removeCommanderBtn.addEventListener('click', async (event) => {
				event.stopPropagation();
				if (inspectorMode === 'commander') {
					const confirmed = window.confirm('Remove commander from this deck?');
					if (!confirmed) return;
					clearCommander();
					return;
				}
				if (inspectorMode === 'deck-row' && inspectedDeckRow) {
					const confirmed = window.confirm(`Remove all ${inspectedDeckRow.count} copies of ${inspectedDeckRow.card.name} from this deck?`);
					if (!confirmed) return;
					await removeInspectedDeckRow();
				}
			});

			proxyToggleBtn.addEventListener('click', async () => {
				const card = getInspectedCard();
				if (!card) return;
				await updateInspectedCard({ proxy: !card.proxy });
			});

			addToCollectionBtn.addEventListener('click', (event) => {
				event.stopPropagation();
				const inspectedCard = getInspectedCard();
				if (!inspectedCard) return;
				const sourceKey = getInspectedCollectionSource();
				if (!sourceKey) {
					window.alert('Could not determine source for this card.');
					return;
				}
				const result = addCardToCollection(inspectedCard, sourceKey);
				window.alert(result.message);
				if (result.ok) {
					renderCommanderInspector();
				}
			});

			commanderInspectorFoilSelect.addEventListener('change', async () => {
				const value = commanderInspectorFoilSelect.value as SlotCard['foil'];
				await updateInspectedCard({ foil: value });
				// Re-open inspector for updated row
				if (inspectorMode === 'deck-row' && inspectedDeckRow) {
					const updatedKey = rowKeyFromCard({ ...inspectedDeckRow.card, foil: value });
					const nextRow = currentRows.find((row) => row.key === updatedKey);
					if (nextRow) {
						openDeckRowInspector(nextRow);
					}
				}
			});

			commanderInspectorLangSelect.addEventListener('change', () => {
				const value = commanderInspectorLangSelect.value;
				void updateInspectedCard({ lang: value });
			});

			closeCommanderInspectorBtn.addEventListener('click', closeCommanderInspector);

			commanderInspectorBackdrop.addEventListener('click', (event) => {
				if (event.target === commanderInspectorBackdrop) {
					closeCommanderInspector();
				}
			});

			commanderSearchCloseBtn.addEventListener('click', () => {
				closeCommanderSearchModal(null);
			});

			commanderSearchBackBtn.addEventListener('click', () => {
				restoreCommanderSearchList();
			});

			commanderSearchBackdrop.addEventListener('click', (event) => {
				if (event.target === commanderSearchBackdrop) {
					closeCommanderSearchModal(null);
				}
			});

			commanderSearchInput.addEventListener('input', () => {
				if (commanderSearchDebounceTimer !== null) {
					window.clearTimeout(commanderSearchDebounceTimer);
				}
				commanderSearchDebounceTimer = window.setTimeout(() => {
					void searchCommanderList(commanderSearchInput.value);
				}, 250);
			});

			deckAddCardInput.addEventListener('input', () => {
				if (!activeDeckName) return;
				const query = deckAddCardInput.value.trim();
				if (query.length < 2) {
					closeDeckSearchPanel();
					return;
				}
				if (deckSearchPanel.hidden) {
					openDeckSearchPanel(deckAddCardInput.value);
				}
				if (deckSearchDebounceTimer !== null) {
					window.clearTimeout(deckSearchDebounceTimer);
				}
				deckSearchDebounceTimer = window.setTimeout(() => {
					void searchDeckCardList(deckAddCardInput.value);
				}, 250);
			});

			deckSearchCloseBtn.addEventListener('click', () => {
				closeDeckSearchPanel();
			});

			deckSearchBackBtn.addEventListener('click', () => {
				restoreDeckSearchList();
			});

			deckEditorForm.addEventListener('submit', (event) => {
				event.preventDefault();
				if (!isCreateMode && !editingDeckName) return;

				const nextName = editDeckNameInput.value.trim();
				const nextColor = /^#[0-9a-fA-F]{6}$/.test(editDeckColorInput.value) ? editDeckColorInput.value : '#2c3e50';
				const nextFormat = parseDeckFormat(editDeckFormatSelect.value);

				if (!nextName) {
					deckEditorStatus.textContent = 'Deck name is required.';
					return;
				}

				const names = readDeckNames();

				if (isCreateMode) {
					if (names.includes(nextName)) {
						deckEditorStatus.textContent = 'A deck with that name already exists.';
						return;
					}

					names.push(nextName);
					saveDeckNames(names);
					deckFormatMap[nextName] = nextFormat;
					deckColorMap[nextName] = '#2c3e50';
					saveDeckFormats(deckFormatMap);
					saveDeckColors(deckColorMap);

					if (!deckMap.has(nextName)) {
						deckMap.set(nextName, []);
					}
					saveDeckMap();

					closeDeckEditor();
					renderDeckHome();
					activeDeckName = nextName;
					activeDeckFormat = nextFormat;
					deckHomeView.hidden = true;
					deckDetailView.hidden = false;
					void renderDeck();
					return;
				}

				const isRename = editingDeckName !== nextName;
				if (isRename && names.includes(nextName)) {
					deckEditorStatus.textContent = 'A deck with that name already exists.';
					return;
				}

				if (isRename) {
					const cards = deckMap.get(editingDeckName) ?? [];
					deckMap.delete(editingDeckName);
					deckMap.set(nextName, cards);

					if (deckFormatMap[editingDeckName]) {
						deckFormatMap[nextName] = deckFormatMap[editingDeckName];
						delete deckFormatMap[editingDeckName];
					}
					if (deckColorMap[editingDeckName]) {
						deckColorMap[nextName] = deckColorMap[editingDeckName];
						delete deckColorMap[editingDeckName];
					}
					if (deckCommanderMap[editingDeckName]) {
						deckCommanderMap[nextName] = deckCommanderMap[editingDeckName];
						delete deckCommanderMap[editingDeckName];
					}

					const renamedNames = names.map((name) => name === editingDeckName ? nextName : name);
					saveDeckNames(renamedNames);
					saveDeckMap();
					if (activeDeckName === editingDeckName) {
						activeDeckName = nextName;
					}
				}

				deckColorMap[nextName] = nextColor;
				deckFormatMap[nextName] = nextFormat;
				saveDeckColors(deckColorMap);
				saveDeckFormats(deckFormatMap);
				saveDeckCommanders(deckCommanderMap);

				closeDeckEditor();
				init();
			});

			deleteDeckBtn.addEventListener('click', () => {
				if (!editingDeckName) return;
				const target = editingDeckName;
				const ok = window.confirm(`Delete deck \"${target}\"? This removes all card assignments to this deck.`);
				if (!ok) return;

				deckMap.delete(target);
				delete deckFormatMap[target];
				delete deckColorMap[target];
				delete deckCommanderMap[target];

				const names = readDeckNames().filter((name) => name !== target);
				saveDeckNames(names);
				saveDeckMap();
				saveDeckFormats(deckFormatMap);
				saveDeckColors(deckColorMap);
				saveDeckCommanders(deckCommanderMap);

				if (activeDeckName === target) {
					activeDeckName = '';
					deckHomeView.hidden = false;
					deckDetailView.hidden = true;
				}

				closeDeckEditor();
				init();
			});

			closeDeckEditorBtn.addEventListener('click', () => {
				closeDeckEditor();
			});

			deckEditorBackdrop.addEventListener('click', (event) => {
				if (event.target === deckEditorBackdrop) {
					closeDeckEditor();
				}
			});

			const goBackToDecks = (): void => {
				activeDeckName = '';
				deckHomeView.hidden = false;
				deckDetailView.hidden = true;
				const url = new URL(window.location.href);
				url.searchParams.delete('name');
				window.history.replaceState({}, '', url.pathname + url.search);
				init();
			};

			backToDecksBtnLeft.addEventListener('click', () => {
				goBackToDecks();
			});

			window.addEventListener('storage', (event) => {
				if (event.key === DECK_CARD_MAP_KEY || event.key === DECK_NAMES_KEY || event.key === DECK_FORMATS_KEY || event.key === DECK_COLORS_KEY || event.key === DECK_COMMANDERS_KEY) {
					init();
				}
			});

			init();
		</script>
	</body>
</html>
