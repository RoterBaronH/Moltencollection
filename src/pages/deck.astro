---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/Moltencollection/favicon.svg" />
		<link href="//cdn.jsdelivr.net/npm/mana-font@latest/css/mana.min.css" rel="stylesheet" type="text/css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>My Decks</title>
		<script src="/Moltencollection/auth.js" is:inline></script>
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: Arial, sans-serif;
				background-color: #1a1a1a;
				color: #fff;
				min-height: 100vh;
			}
			.ms {
				line-height: 1;
				vertical-align: middle;
			}
			.ms-cost {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 1.12em;
				height: 1.12em;
				font-size: 1em;
			}
			.ms-cost::before {
				font-size: 0.8em;
			}
			.ms-cost.ms-w::before,
			.ms-cost.ms-u::before,
			.ms-cost.ms-b::before,
			.ms-cost.ms-r::before,
			.ms-cost.ms-g::before {
				font-size: 0.88em;
			}
			.nav {
				display: flex;
				gap: 0;
				background-color: #333;
			}
			.nav-btn {
				flex: 1;
				padding: 15px 20px;
				background-color: #333;
				color: white;
				text-decoration: none;
				text-align: center;
				cursor: pointer;
				border: none;
				border-right: 1px solid #555;
				transition: background-color 0.3s;
			}
			.nav-btn:hover {
				background-color: #555;
			}
			.nav-btn.active {
				background-color: #0066cc;
			}
			.nav-btn:last-child {
				border-right: none;
			}
			main {
				padding: 0;
				margin: 0;
			}
			#deck-home-view > h1,
			#deck-home-view > p {
				padding: 20px;
				max-width: 1000px;
				margin: 0;
				color: #fff;
			}
			#deck-home-view > p {
				color: #fff;
			}
			.deck-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 24px;
				padding: 24px 20px;
				max-width: 1200px;
				margin: 0;
			}
			.deck-card {
				position: relative;
				width: 150px;
				height: 180px;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 10px;
				padding: 16px 12px;
				text-align: center;
				border-radius: 14px;
				border: 0;
				font-family: inherit;
				cursor: pointer;
				background: #2c3e50;
				color: #fff;
				text-decoration: none;
				box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
				transition: transform 0.2s, box-shadow 0.2s;
				overflow: hidden;
			}
			.deck-card.select-deck-card {
				cursor: grab;
				padding-top: 36px;
			}
			.deck-card.select-deck-card.is-dragging {
				opacity: 0.45;
			}
			.deck-card.select-deck-card.is-drop-target {
				outline: 2px dashed rgba(255, 255, 255, 0.9);
				outline-offset: 4px;
			}
			.deck-card:hover {
				transform: translateY(-6px);
				filter: brightness(1.15);
				box-shadow: 0 14px 24px rgba(0, 0, 0, 0.5);
			}
			.deck-card-name {
				margin: 0;
				font-size: 1.1rem;
				font-weight: bold;
				text-align: center;
				line-height: 1.2;
				word-break: break-word;
			}
			.deck-card-format {
				position: absolute;
				top: 8px;
				left: 50%;
				transform: translateX(-50%);
				display: inline-flex;
				align-items: center;
				padding: 3px 9px;
				border-radius: 999px;
				background: rgba(10, 14, 18, 0.45);
				border: 1px solid rgba(255, 255, 255, 0.45);
				font-size: 11px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				white-space: nowrap;
			}
			.deck-card-colors {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 4px;
				margin-top: 2px;
			}
			.deck-card-colors .ms {
				font-size: 14px;
			}
			.deck-card-colors .ms-cost::before {
				font-size: 0.88em;
			}
			.add-deck-card {
				background: rgba(255, 255, 255, 0.75);
				backdrop-filter: blur(4px);
				color: #333;
				font-size: 1.25rem;
				font-weight: bold;
				line-height: 1;
			}
			.add-deck-card .plus {
				font-size: 3rem;
				line-height: 1;
			}
			.add-deck-card:hover {
				background: rgba(255, 255, 255, 0.9);
			}
			.deck-edit-btn {
				position: absolute;
				bottom: 8px;
				right: 8px;
				z-index: 2;
				padding: 4px 8px;
				border: none;
				border-radius: 6px;
				background: rgba(0, 0, 0, 0.55);
				color: #fff;
				font-size: 11px;
				cursor: pointer;
				transition: background 0.2s;
			}
			.deck-edit-btn:hover {
				background: rgba(0, 0, 0, 0.8);
			}
			.deck-editor-backdrop {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.7);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				z-index: 1000;
			}
			.deck-editor-backdrop[hidden] {
				display: none;
			}
			.deck-editor-modal {
				width: 100%;
				max-width: 560px;
				background: #26323d;
				border: 1px solid #3a4a58;
				border-radius: 12px;
				padding: 20px;
				position: relative;
				color: #fff;
			}
			.deck-editor-close {
				position: absolute;
				top: 10px;
				right: 10px;
				width: 30px;
				height: 30px;
				border: none;
				border-radius: 8px;
				background: #374757;
				color: #fff;
				font-size: 18px;
				line-height: 1;
				cursor: pointer;
			}
			.deck-editor-close:hover {
				background: #4a5f73;
			}
			.deck-editor-modal h2 {
				margin-bottom: 14px;
			}
			.deck-editor-modal label {
				display: block;
				font-weight: 700;
				margin-bottom: 8px;
			}
			.deck-color-row[hidden] {
				display: none;
			}
			.deck-editor-modal input,
			.deck-editor-modal select {
				width: 100%;
				padding: 10px 12px;
				margin-bottom: 14px;
				border: 1px solid #55697b;
				border-radius: 8px;
				background: #1f2a33;
				color: #fff;
				font-size: 16px;
			}
			.deck-editor-modal input[type='color'] {
				height: 50px;
				padding: 5px;
			}
			.deck-editor-actions {
				display: flex;
				gap: 10px;
				margin-top: 6px;
			}
			.deck-editor-actions button {
				padding: 10px 14px;
				border: none;
				border-radius: 8px;
				font-size: 15px;
				cursor: pointer;
			}
			#save-deck-btn {
				background: #2ea043;
				color: #fff;
				margin-left: auto;
			}
			#delete-deck-btn {
				background: #c03636;
				color: #fff;
			}
			#deck-editor-status {
				margin-top: 12px;
				font-size: 14px;
				color: #9dd8a8;
			}
			.back-btn {
				padding: 10px 12px;
				border-radius: 8px;
				border: 1px solid #41586b;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
				cursor: pointer;
			}
			.back-btn:hover {
				background: #1b2633;
			}
			.deck-header {
				display: flex;
				justify-content: flex-start;
				align-items: flex-start;
				gap: 12px;
				flex-wrap: wrap;
				padding: 20px 20px 0;
				margin-bottom: 8px;
			}
			.deck-title {
				font-size: 30px;
				font-weight: 700;
			}
			.deck-title-wrap {
				display: flex;
				align-items: center;
				gap: 10px;
				flex-wrap: wrap;
			}
			.deck-format-pill {
				display: inline-flex;
				align-items: center;
				padding: 6px 10px;
				border-radius: 999px;
				background: #1f2f3f;
				border: 1px solid #324457;
				font-size: 12px;
				font-weight: 700;
				color: #dbe8f5;
			}
			.deck-controls {
				display: flex;
				gap: 10px;
				align-items: center;
				flex-wrap: wrap;
				justify-content: flex-start;
			}
			.select,
			.input {
				padding: 10px 12px;
				border-radius: 8px;
				border: 1px solid #41586b;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
			}
			.select {
				min-width: 240px;
			}
			.input {
				min-width: 280px;
			}
			.status {
				display: none;
			}
			.deck-layout {
				display: grid;
				grid-template-columns: 360px minmax(0, 1fr);
				gap: 14px;
				padding: 0 20px 20px;
				width: 100%;
				align-items: start;
			}
			.panel {
				background: #111923;
				border: 1px solid #324457;
				border-radius: 12px;
			}
			.deck-list-panel {
				grid-column: 2;
				grid-row: 1;
			}
			.deck-list-head {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 10px;
				padding: 12px;
				border-bottom: 1px solid #2a3a4a;
			}
			.deck-add-card-wrap {
				display: flex;
				gap: 8px;
				width: 100%;
			}
			.deck-add-card-input {
				flex: 1;
				min-width: 0;
				padding: 10px 12px;
				border-radius: 8px;
				border: 1px solid #3a5064;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
			}

			.deck-search-panel {
				display: flex;
				flex-direction: column;
				gap: 10px;
				padding: 12px;
				border-top: 1px solid #2a3a4a;
			}
			.deck-search-panel[hidden] {
				display: none;
			}
			.deck-search-head {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 10px;
			}
			.deck-search-title {
				font-size: 16px;
				font-weight: 700;
				color: #f4f8fc;
			}
			.deck-search-actions {
				display: flex;
				gap: 8px;
				align-items: center;
			}
			.deck-search-back,
			.deck-search-close {
				padding: 8px 12px;
				border-radius: 8px;
				border: none;
				background: #2f81f7;
				color: #fff;
				cursor: pointer;
			}
			.deck-search-close {
				width: 34px;
				height: 34px;
				padding: 0;
				font-size: 22px;
				line-height: 1;
			}
			.deck-search-status {
				font-size: 13px;
				color: #9db0bf;
			}
			.deck-search-results {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 10px;
				max-height: 420px;
				overflow: auto;
				padding-right: 2px;
			}
			.deck-sections {
				padding: 10px;
				display: flex;
				flex-direction: column;
				gap: 14px;
			}
			.deck-section {
				border-bottom: 1px solid #273646;
				padding-bottom: 10px;
				overflow: hidden;
				background: transparent;
			}
			.deck-section:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.deck-card-grid {
				display: flex;
				flex-direction: column;
				gap: 0;
				padding: 0;
			}
			.deck-section-head {
				background: transparent;
				padding: 0 0 8px;
				display: flex;
				align-items: center;
				justify-content: flex-start;
				gap: 8px;
				font-size: 12px;
				font-weight: 700;
				color: #9db0bf;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
			.deck-section-name,
			.deck-section-count {
				display: inline-flex;
				align-items: center;
			}
			.deck-section-count {
				padding: 0;
				border: none;
				background: transparent;
				font-size: 12px;
			}
			.deck-row {
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 7px 0;
				border: none;
				border-radius: 0;
				background: transparent;
				cursor: pointer;
				text-align: left;
				width: 100%;
				margin-top: 0;
				border-bottom: 1px solid rgba(39, 54, 70, 0.8);
			}
			.deck-row:last-child {
				border-bottom: none;
			}
			.deck-row:hover {
				background: rgba(255, 255, 255, 0.03);
			}
			.deck-row.is-proxy {
				opacity: 0.7;
			}
			.deck-row-proxy-badge {
				display: inline-block;
				padding: 0 4px;
				margin-left: 4px;
				border-radius: 3px;
				background: #b8930b;
				color: #000;
				font-size: 10px;
				font-weight: 700;
				line-height: 1.5;
				vertical-align: middle;
			}
			.deck-row-qty {
				width: 28px;
				flex-shrink: 0;
				font-size: 13px;
				font-weight: 700;
				color: #dbe8f5;
				text-align: right;
			}
			.deck-row-name {
				flex: 1;
				min-width: 0;
				font-size: 14px;
				font-weight: 500;
				color: #f0f6fc;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.deck-row-cost {
				margin-left: auto;
				font-size: 12px;
				font-weight: 600;
				color: #9db0bf;
				white-space: nowrap;
				display: inline-flex;
				align-items: center;
				gap: 2px;
			}
			.deck-row-cost .ms {
				font-size: 15px;
				line-height: 1;
			}

			.stats {
				grid-column: 1;
				grid-row: 1;
				width: 100%;
				padding: 12px;
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.commander-preview {
				position: relative;
				width: 100%;
				border: 0;
				padding: 0;
				background: transparent;
				cursor: pointer;
				overflow: hidden;
				border-radius: 10px;
			}
			.commander-preview.preview-foil::after,
			.commander-preview.preview-etched::after {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				border-radius: 10px;
			}
			.commander-preview.preview-foil::after {
				background:
					linear-gradient(115deg, rgba(255, 255, 255, 0.34) 6%, rgba(255, 255, 255, 0.02) 24%, rgba(255, 255, 255, 0.28) 40%, rgba(255, 255, 255, 0.03) 58%, rgba(255, 255, 255, 0.22) 78%, rgba(255, 255, 255, 0.04) 100%),
					linear-gradient(135deg, rgba(147, 197, 253, 0.24) 16%, rgba(244, 114, 182, 0.21) 52%, rgba(250, 204, 21, 0.24) 84%);
				mix-blend-mode: screen;
			}
			.commander-preview.preview-etched::after {
				background:
					linear-gradient(120deg, rgba(255, 248, 220, 0.28) 8%, rgba(255, 248, 220, 0.02) 46%, rgba(255, 248, 220, 0.22) 88%),
					linear-gradient(145deg, rgba(245, 158, 11, 0.24) 0%, rgba(120, 53, 15, 0.18) 40%, rgba(253, 230, 138, 0.24) 100%);
				mix-blend-mode: screen;
			}
			.commander-preview.is-static {
				cursor: default;
			}
			.preview {
				width: 100%;
				aspect-ratio: 5 / 7;
				border-radius: 10px;
				background: #0d1117;
				border: 1px solid #273646;
				object-fit: cover;
			}
			.commander-inspector-backdrop {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.72);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 24px;
				z-index: 60;
			}
			.commander-inspector-backdrop[hidden] {
				display: none;
			}
			.commander-inspector-modal {
				width: min(980px, 100%);
				max-height: 84vh;
				overflow: hidden;
				border-radius: 14px;
				border: 1px solid #324457;
				background: #111923;
				display: grid;
				grid-template-columns: minmax(280px, 360px) 1fr;
			}
			.commander-inspector-left {
				padding: 16px;
				border-right: 1px solid #2a3a4a;
				display: flex;
				position: relative;
				justify-content: center;
				align-items: flex-start;
				overflow: auto;
			}
			.commander-inspector-left.inspector-foil::after,
			.commander-inspector-left.inspector-etched::after {
				content: '';
				position: absolute;
				inset: 16px;
				pointer-events: none;
				border-radius: 10px;
			}
			.commander-inspector-left.inspector-foil::after {
				background:
					linear-gradient(115deg, rgba(255, 255, 255, 0.44) 6%, rgba(255, 255, 255, 0.03) 24%, rgba(255, 255, 255, 0.36) 40%, rgba(255, 255, 255, 0.04) 58%, rgba(255, 255, 255, 0.3) 78%, rgba(255, 255, 255, 0.06) 100%),
					linear-gradient(135deg, rgba(147, 197, 253, 0.28) 16%, rgba(244, 114, 182, 0.24) 52%, rgba(250, 204, 21, 0.28) 84%);
				mix-blend-mode: screen;
			}
			.commander-inspector-left.inspector-etched::after {
				background:
					linear-gradient(120deg, rgba(255, 248, 220, 0.34) 8%, rgba(255, 248, 220, 0.03) 46%, rgba(255, 248, 220, 0.28) 88%),
					linear-gradient(145deg, rgba(245, 158, 11, 0.3) 0%, rgba(120, 53, 15, 0.2) 40%, rgba(253, 230, 138, 0.3) 100%);
				mix-blend-mode: screen;
			}
			.commander-inspector-image {
				width: 100%;
				max-width: 320px;
				border-radius: 10px;
				box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45);
				display: block;
			}
			.commander-inspector-right {
				display: flex;
				flex-direction: column;
				min-height: 0;
			}
			.commander-inspector-header {
				padding: 14px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 10px;
				border-bottom: 1px solid #2a3a4a;
			}
			.commander-inspector-title {
				font-size: 16px;
				font-weight: 700;
				color: #e7f0f8;
			}
			.commander-inspector-meta,
			.commander-inspector-price {
				margin-top: 4px;
				font-size: 12px;
				color: #9db0bf;
			}
			.commander-inspector-actions {
				display: flex;
				align-items: center;
				display: flex;
				gap: 8px;
			}
			.commander-inspector-remove,
			.commander-inspector-add,
			.commander-inspector-proxy,
			.commander-inspector-close,
			.commander-inspector-option {
				padding: 8px 10px;
				border-radius: 8px;
				color: #fff;
				cursor: pointer;
				font-size: 12px;
				line-height: 1;
			}
			.commander-inspector-remove {
				border: 1px solid #8b1d1d;
				background: #c03636;
			}
			.commander-inspector-remove:hover {
				background: #dc4a4a;
			}
			.commander-inspector-add {
				border: 1px solid #1f7a35;
				background: #2ea043;
			}
			.commander-inspector-add:hover {
				background: #3bb257;
			}
			.commander-inspector-add:disabled {
				border: 1px solid #5a6470;
				background: #6b7280;
				color: #d4d8de;
				cursor: not-allowed;
			}
			.commander-inspector-add:disabled:hover {
				background: #6b7280;
			}
			.commander-inspector-proxy {
				border: 1px solid #6b5b00;
				background: #8a7200;
				color: #fff;
			}
			.commander-inspector-proxy:hover {
				background: #a38800;
			}
			.commander-inspector-proxy.is-proxy {
				border: 1px solid #c9a800;
				background: #d4a80e;
				color: #000;
			}
			.commander-inspector-proxy.is-proxy:hover {
				background: #e6bb1a;
			}
			.commander-inspector-close {
				border: 0;
				background: #2e404f;
			}
			.commander-inspector-close:hover {
				background: #3d5a6e;
			}
			.commander-inspector-controls {
				padding: 12px 14px;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 10px;
				border-bottom: 1px solid #2a3a4a;
			}
			.commander-inspector-field {
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.commander-inspector-label {
				font-size: 12px;
				color: #9db0bf;
			}
			.commander-inspector-select {
				padding: 9px 10px;
				border-radius: 8px;
				border: 1px solid #3a5064;
				background: #0d1117;
				color: #fff;
				font-size: 13px;
			}
			.commander-inspector-option {
				border: 0;
				background: #2a3745;
				text-align: left;
				grid-column: 1 / -1;
				padding: 10px 12px;
				line-height: 1.2;
			}
			.commander-inspector-option:hover {
				background: #394a5c;
			}
			.commander-inspector-errata {
				padding: 12px 14px;
				display: flex;
				flex-direction: column;
				gap: 6px;
				min-height: 0;
				overflow: auto;
			}
			.commander-inspector-errata-title {
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: #dbe8f5;
			}
			.commander-inspector-errata-text {
				white-space: pre-wrap;
				line-height: 1.4;
				font-size: 13px;
				color: #c6d4e1;
			}
			.commander-inspector-errata-text .ms {
				font-size: 15px;
				line-height: 1;
				margin: 0 1px;
			}
			.commander-search-backdrop {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.72);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 24px;
				z-index: 61;
			}
			.commander-search-backdrop[hidden] {
				display: none;
			}
			.commander-search-modal {
				width: min(860px, 100%);
				max-height: 84vh;
				display: flex;
				flex-direction: column;
				gap: 12px;
				padding: 16px;
				border-radius: 14px;
				border: 1px solid #324457;
				background: #111923;
			}
			.commander-search-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 10px;
			}
			.commander-search-title {
				font-size: 18px;
				font-weight: 700;
				color: #f4f8fc;
			}
			.commander-search-actions {
				display: flex;
				gap: 8px;
				align-items: center;
			}
			.commander-search-back,
			.commander-search-close {
				padding: 8px 12px;
				border-radius: 8px;
				border: none;
				background: #2f81f7;
				color: #fff;
				cursor: pointer;
			}
			.commander-search-close {
				width: 34px;
				height: 34px;
				padding: 0;
				font-size: 22px;
				line-height: 1;
			}
			.commander-search-input {
				width: 100%;
				padding: 10px 12px;
				border-radius: 8px;
				border: 1px solid #3a5064;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
			}
			.commander-search-status {
				font-size: 13px;
				color: #9db0bf;
			}
			.commander-search-results {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 10px;
				overflow: auto;
				padding-right: 2px;
			}
			.commander-result {
				display: flex;
				gap: 10px;
				align-items: center;
				width: 100%;
				padding: 8px;
				border-radius: 10px;
				border: 1px solid #2f4254;
				background: #162331;
				color: #e5eff8;
				text-align: left;
				cursor: pointer;
			}
			.commander-result:hover {
				background: #1c2e3f;
			}
			.commander-result img {
				width: 54px;
				height: 75px;
				border-radius: 6px;
				object-fit: cover;
				flex-shrink: 0;
			}
			.commander-result-name {
				font-size: 14px;
				font-weight: 700;
			}
			.commander-result-sub {
				font-size: 12px;
				color: #a9bbca;
				margin-top: 2px;
			}
			@media (max-width: 760px) {
				.commander-inspector-modal {
					grid-template-columns: 1fr;
				}
				.commander-inspector-left {
					border-right: 0;
					border-bottom: 1px solid #2a3a4a;
				}
				.commander-inspector-header {
					flex-direction: column;
				}
				.commander-search-modal {
					padding: 12px;
				}
				.commander-search-results {
					grid-template-columns: 1fr;
				}
				.deck-search-results {
					grid-template-columns: 1fr;
				}
			}
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 8px;
			}
			.stat-box {
				border: 1px solid #273646;
				border-radius: 8px;
				padding: 8px;
				background: #131f2c;
			}
			.stat-label {
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: #9db0bf;
			}
			.stat-value {
				font-size: 18px;
				font-weight: 700;
				color: #e7f2fb;
			}
			.colors {
				display: flex;
				gap: 6px;
				flex-wrap: wrap;
			}
			.color-chip {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 2px;
				border-radius: 999px;
				font-size: 12px;
				border: 0;
				background: transparent;
			}
			.color-chip .ms {
				font-size: 16px;
			}
			.color-chip .ms-cost::before {
				font-size: 0.88em;
			}
			.color-W { background: #f4f5f7; color: #111; }
			.color-U { background: #1d4ed8; color: #dbeafe; }
			.color-B { background: #111827; color: #f3f4f6; }
			.color-R { background: #b91c1c; color: #fee2e2; }
			.color-G { background: #166534; color: #dcfce7; }
			.curve {
				display: flex;
				align-items: flex-end;
				gap: 6px;
				height: 120px;
				padding-top: 8px;
			}
			.curve-col {
				flex: 1;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 4px;
			}
			.curve-bar {
				width: 100%;
				min-height: 2px;
				background: linear-gradient(180deg, #4da3ff, #1f6feb);
				border-radius: 4px 4px 0 0;
			}
			.curve-num {
				font-size: 11px;
				color: #9db0bf;
			}
			.empty {
				padding: 20px;
				color: #b9c9d6;
				border: 1px solid #324457;
				border-radius: 12px;
				background: #111923;
				margin: 0 20px 20px;
				max-width: 1100px;
			}
			@media (max-width: 1100px) {
				.deck-layout {
					grid-template-columns: 1fr;
				}
				.deck-list-panel,
				.stats {
					grid-column: auto;
					grid-row: auto;
				}
				.input,
				.select {
					min-width: 0;
					width: 100%;
				}
				.deck-controls {
					width: 100%;
				}
				.deck-row {
					padding: 7px 0;
				}
				.deck-row-cost {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<nav class="nav">
			<a href="/Moltencollection/" class="nav-btn">Home</a>
			<a href="/Moltencollection/binders" class="nav-btn">My Binders</a>
			<a href="/Moltencollection/deck" class="nav-btn active">My Decks</a>
			<a href="/Moltencollection/collections" class="nav-btn">Collection</a>
		</nav>

		<main>
			<section id="deck-home-view">
				<h1>My Decks</h1>
				<p>Create and manage your MTG decks here.</p>
				<div id="deck-grid" class="deck-grid">
					<button id="open-deck-btn" class="deck-card add-deck-card auth-required" type="button" title="Create new deck">
						<span class="plus">+</span>
						<span>Add Deck</span>
					</button>
				</div>

				<div id="deck-editor-backdrop" class="deck-editor-backdrop" hidden>
					<div class="deck-editor-modal">
						<button id="close-deck-editor-btn" class="deck-editor-close" type="button" aria-label="Close">&times;</button>
						<h2 id="deck-editor-title">Edit Deck</h2>
						<form id="deck-editor-form">
							<label for="edit-deck-name">Name</label>
							<input id="edit-deck-name" type="text" maxlength="50" required />

							<div id="deck-color-row" class="deck-color-row">
								<label for="edit-deck-color">Color</label>
								<input id="edit-deck-color" type="color" value="#2c3e50" />
							</div>

							<label for="edit-deck-format">Format</label>
							<select id="edit-deck-format">
								<option value="commander">Commander</option>
								<option value="standard">Standard</option>
								<option value="modern">Modern</option>
								<option value="pioneer">Pioneer</option>
								<option value="legacy">Legacy</option>
								<option value="vintage">Vintage</option>
								<option value="pauper">Pauper</option>
								<option value="brawl">Brawl</option>
								<option value="custom">Custom</option>
							</select>

							<div class="deck-editor-actions">
								<button id="delete-deck-btn" type="button">Delete</button>
								<button id="save-deck-btn" type="submit">Save</button>
							</div>
							<p id="deck-editor-status" aria-live="polite"></p>
						</form>
					</div>
				</div>
			</section>

			<section id="deck-detail-view" hidden>
				<div class="deck-header">
					<div class="deck-title-wrap">
						<button id="back-to-decks-btn-left" class="back-btn" type="button" title="Back to decks">&larr; Back</button>
						<h1 class="deck-title" id="deck-detail-title">My Decks</h1>
						<span id="deck-detail-format" class="deck-format-pill">Custom</span>
					</div>
					<div class="deck-controls"></div>
				</div>

				<div id="deck-status" class="status"></div>
				<div id="deck-layout" class="deck-layout" hidden>
					<section class="panel deck-list-panel">
						<div class="deck-list-head">
							<div class="deck-add-card-wrap auth-required">
								<input id="deck-add-card-input" class="deck-add-card-input" type="text" placeholder="Search and add cards" autocomplete="off" />
							</div>
						</div>
						<div id="deck-search-panel" class="deck-search-panel" hidden>
							<div class="deck-search-head">
								<span id="deck-search-title" class="deck-search-title">Search Cards</span>
								<div class="deck-search-actions">
									<button id="deck-search-back" class="deck-search-back" type="button" hidden>Back</button>
									<button id="deck-search-close" class="deck-search-close" type="button" aria-label="Close">&times;</button>
								</div>
							</div>
							<div id="deck-search-status" class="deck-search-status">Type at least 2 characters to search.</div>
							<div id="deck-search-results" class="deck-search-results"></div>
						</div>
						<div id="deck-sections" class="deck-sections"></div>
					</section>
					<aside class="panel stats">
						<button id="commander-preview" class="commander-preview is-static" type="button">
							<img id="deck-preview" class="preview" src="/Moltencollection/favicon.svg" alt="Card preview" />
						</button>
						<div class="stats-grid">
							<div class="stat-box"><div class="stat-label">Card Count</div><div id="stat-cards" class="stat-value">0</div></div>
							<div id="sideboard-stat" class="stat-box" hidden><div class="stat-label">Sideboard</div><div id="stat-sideboard" class="stat-value">0/15</div></div>
							<div class="stat-box"><div class="stat-label">Avg MV</div><div id="stat-avg-mv" class="stat-value">0.00</div></div>
							<div class="stat-box"><div class="stat-label">Price</div><div id="stat-price" class="stat-value">EUR 0.00</div></div>
							<div class="stat-box"><div class="stat-label">Nonlands</div><div id="stat-nonlands" class="stat-value">0</div></div>
						</div>
						<div>
							<div class="stat-label" style="margin-bottom:6px">Color Distribution</div>
							<div id="deck-colors" class="colors"></div>
						</div>
						<div>
							<div class="stat-label" style="margin-bottom:6px">Mana Curve</div>
							<div id="deck-curve" class="curve"></div>
						</div>
					</aside>
				</div>

				<div id="commander-inspector-backdrop" class="commander-inspector-backdrop" hidden>
					<div class="commander-inspector-modal" role="dialog" aria-modal="true" aria-labelledby="commander-inspector-title">
						<div class="commander-inspector-left">
							<img id="commander-inspector-image" class="commander-inspector-image" alt="Commander" src="/Moltencollection/favicon.svg" />
						</div>
						<div class="commander-inspector-right">
							<div class="commander-inspector-header">
								<div>
									<div id="commander-inspector-title" class="commander-inspector-title">Commander</div>
									<div id="commander-inspector-meta" class="commander-inspector-meta"></div>
									<div id="commander-inspector-price" class="commander-inspector-price"></div>
								</div>
								<div class="commander-inspector-actions">
									<button id="remove-commander-btn" class="commander-inspector-remove auth-required" type="button">Remove</button>
									<button id="proxy-toggle-btn" class="commander-inspector-proxy auth-required" type="button">Proxy</button>
									<button id="add-to-collection-btn" class="commander-inspector-add auth-required" type="button">Add to Collection</button>
									<button id="close-commander-inspector-btn" class="commander-inspector-close" type="button" aria-label="Close">&times;</button>
								</div>
							</div>
							<div class="commander-inspector-controls auth-required">
								<button id="change-commander-btn" class="commander-inspector-option" type="button">Select Version</button>
								<div class="commander-inspector-field">
									<label for="commander-inspector-foil" class="commander-inspector-label">Foiling</label>
									<select id="commander-inspector-foil" class="commander-inspector-select">
										<option value="nonfoil">Nonfoil</option>
										<option value="foil">Foil</option>
										<option value="etched">Etched</option>
									</select>
								</div>
								<div class="commander-inspector-field">
									<label for="commander-inspector-lang" class="commander-inspector-label">Language</label>
									<select id="commander-inspector-lang" class="commander-inspector-select">
										<option value="en">English</option>
										<option value="es">Spanish</option>
										<option value="fr">French</option>
										<option value="de">German</option>
										<option value="it">Italian</option>
										<option value="pt">Portuguese</option>
										<option value="ja">Japanese</option>
										<option value="ko">Korean</option>
										<option value="ru">Russian</option>
										<option value="zhs">Chinese Simplified</option>
										<option value="zht">Chinese Traditional</option>
									</select>
								</div>
							</div>
							<div class="commander-inspector-errata">
								<div class="commander-inspector-errata-title">Oracle Text</div>
								<div id="commander-inspector-errata" class="commander-inspector-errata-text">Loading...</div>
							</div>
						</div>
					</div>
				</div>

				<div id="commander-search-backdrop" class="commander-search-backdrop" hidden>
					<div class="commander-search-modal" role="dialog" aria-modal="true" aria-labelledby="commander-search-title">
						<div class="commander-search-header">
							<span id="commander-search-title" class="commander-search-title">Search Commander</span>
							<div class="commander-search-actions">
								<button id="commander-search-back" class="commander-search-back" type="button" hidden>Back</button>
								<button id="commander-search-close" class="commander-search-close" type="button" aria-label="Close">&times;</button>
							</div>
						</div>
						<input id="commander-search-input" class="commander-search-input" type="text" placeholder="Search commander name" autocomplete="off" />
						<div id="commander-search-status" class="commander-search-status">Type at least 2 characters to search.</div>
						<div id="commander-search-results" class="commander-search-results"></div>
					</div>
				</div>
			</section>
		</main>

		<script>
			type SlotCard = {
				id: string;
				name: string;
				imageUrl: string | null;
				imageUrlLarge?: string | null;
				scryfallUri: string;
				setCode?: string;
				setName?: string;
				collectorNumber?: string;
				lang?: string;
				foil?: 'nonfoil' | 'foil' | 'etched';
				collectionSource?: string;
				inDeck?: boolean;
				deckName?: string;
				proxy?: boolean;
			};

			type ScryfallSearchCard = {
				id: string;
				name: string;
				scryfall_uri: string;
				prints_search_uri?: string;
				digital?: boolean;
				set?: string;
				set_name?: string;
				collector_number?: string;
				lang?: string;
				image_uris?: { small?: string; normal?: string };
				card_faces?: Array<{ image_uris?: { small?: string; normal?: string } }>;
			};

			type ScryfallOracleCard = {
				type_line?: string;
				oracle_text?: string;
				card_faces?: Array<{
					type_line?: string;
					oracle_text?: string;
				}>;
			};

			type DeckFormat = 'commander' | 'standard' | 'modern' | 'pioneer' | 'legacy' | 'vintage' | 'pauper' | 'brawl' | 'custom';

			type CardMeta = {
				cmc: number;
				manaCost: string;
				typeLine: string;
				colorIdentity: string[];
				priceEur: string;
				priceEurFoil: string;
				priceUsd: string;
				priceUsdFoil: string;
			};

			type DeckRow = {
				key: string;
				count: number;
				card: SlotCard;
				meta: CardMeta;
				section: string;
				price: number;
			};

			type BinderSlotValue = SlotCard | string | null;

			type BinderStorage = {
				id: number;
				name: string;
				color?: string;
				pages?: BinderSlotValue[][];
			};

			const DECK_CARD_MAP_KEY = 'mtgDeckCards';
			const DECK_NAMES_KEY = 'mtgDeckNames';
			const DECK_FORMATS_KEY = 'mtgDeckFormats';
			const DECK_COLORS_KEY = 'mtgDeckColors';
			const DECK_COMMANDERS_KEY = 'mtgDeckCommanders';
			const META_CACHE_KEY = 'mtgDeckCardMeta';
			const BINDER_STORAGE_KEY = 'mtgBinders';
			const COLLECTION_STORAGE_KEY = 'mtgCollection';
			const BINDER_SLOTS_PER_PAGE = 9;

			const deckHomeView = document.getElementById('deck-home-view') as HTMLElement;
			const deckDetailView = document.getElementById('deck-detail-view') as HTMLElement;
			const deckGrid = document.getElementById('deck-grid') as HTMLElement;
			const openDeckBtn = document.getElementById('open-deck-btn') as HTMLButtonElement;
			const deckEditorBackdrop = document.getElementById('deck-editor-backdrop') as HTMLElement;
			const deckEditorTitle = document.getElementById('deck-editor-title') as HTMLElement;
			const deckEditorForm = document.getElementById('deck-editor-form') as HTMLFormElement;
			const editDeckNameInput = document.getElementById('edit-deck-name') as HTMLInputElement;
			const deckColorRow = document.getElementById('deck-color-row') as HTMLElement;
			const editDeckColorInput = document.getElementById('edit-deck-color') as HTMLInputElement;
			const editDeckFormatSelect = document.getElementById('edit-deck-format') as HTMLSelectElement;
			const saveDeckBtn = document.getElementById('save-deck-btn') as HTMLButtonElement;
			const deleteDeckBtn = document.getElementById('delete-deck-btn') as HTMLButtonElement;
			const closeDeckEditorBtn = document.getElementById('close-deck-editor-btn') as HTMLButtonElement;
			const deckEditorStatus = document.getElementById('deck-editor-status') as HTMLElement;
			const deckDetailTitle = document.getElementById('deck-detail-title') as HTMLElement;
			const deckDetailFormat = document.getElementById('deck-detail-format') as HTMLElement;
			const backToDecksBtnLeft = document.getElementById('back-to-decks-btn-left') as HTMLButtonElement;
			const deckLayout = document.getElementById('deck-layout') as HTMLElement;
			const deckAddCardInput = document.getElementById('deck-add-card-input') as HTMLInputElement;
			const deckSearchPanel = document.getElementById('deck-search-panel') as HTMLDivElement;
			const deckSearchTitle = document.getElementById('deck-search-title') as HTMLSpanElement;
			const deckSearchBackBtn = document.getElementById('deck-search-back') as HTMLButtonElement;
			const deckSearchCloseBtn = document.getElementById('deck-search-close') as HTMLButtonElement;
			const deckSearchStatus = document.getElementById('deck-search-status') as HTMLDivElement;
			const deckSearchResults = document.getElementById('deck-search-results') as HTMLDivElement;
			const deckSections = document.getElementById('deck-sections') as HTMLElement;
			const deckPreview = document.getElementById('deck-preview') as HTMLImageElement;
			const commanderPreview = document.getElementById('commander-preview') as HTMLButtonElement;
			const commanderInspectorBackdrop = document.getElementById('commander-inspector-backdrop') as HTMLDivElement;
			const commanderInspectorLeft = document.querySelector('.commander-inspector-left') as HTMLDivElement;
			const commanderInspectorImage = document.getElementById('commander-inspector-image') as HTMLImageElement;
			const commanderInspectorTitle = document.getElementById('commander-inspector-title') as HTMLDivElement;
			const commanderInspectorMeta = document.getElementById('commander-inspector-meta') as HTMLDivElement;
			const commanderInspectorPrice = document.getElementById('commander-inspector-price') as HTMLDivElement;
			const commanderInspectorErrata = document.getElementById('commander-inspector-errata') as HTMLDivElement;
			const closeCommanderInspectorBtn = document.getElementById('close-commander-inspector-btn') as HTMLButtonElement;
			const changeCommanderBtn = document.getElementById('change-commander-btn') as HTMLButtonElement;
			const commanderInspectorFoilSelect = document.getElementById('commander-inspector-foil') as HTMLSelectElement;
			const commanderInspectorLangSelect = document.getElementById('commander-inspector-lang') as HTMLSelectElement;
			const removeCommanderBtn = document.getElementById('remove-commander-btn') as HTMLButtonElement;
			const proxyToggleBtn = document.getElementById('proxy-toggle-btn') as HTMLButtonElement;
