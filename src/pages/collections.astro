---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/Moltencollection/favicon.svg" />
		<link href="//cdn.jsdelivr.net/npm/mana-font@latest/css/mana.min.css" rel="stylesheet" type="text/css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Collection</title>
		<script src="/Moltencollection/auth.js" is:inline></script>
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			body {
				font-family: Arial, sans-serif;
				background-color: #1a1a1a;
				color: #fff;
				min-height: 100vh;
			}
			.ms {
				line-height: 1;
				vertical-align: middle;
			}
			.ms-cost {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 1.12em;
				height: 1.12em;
				font-size: 1em;
			}
			.ms-cost::before {
				font-size: 0.8em;
			}
			.ms-cost.ms-w::before,
			.ms-cost.ms-u::before,
			.ms-cost.ms-b::before,
			.ms-cost.ms-r::before,
			.ms-cost.ms-g::before {
				font-size: 0.88em;
			}
			.nav {
				display: flex;
				gap: 0;
				background-color: #333;
			}
			.nav-btn {
				flex: 1;
				padding: 15px 20px;
				background-color: #333;
				color: white;
				text-decoration: none;
				text-align: center;
				cursor: pointer;
				border: none;
				border-right: 1px solid #555;
				transition: background-color 0.3s;
			}
			.nav-btn:hover {
				background-color: #555;
			}
			.nav-btn.active {
				background-color: #0066cc;
			}
			.nav-btn:last-child {
				border-right: none;
			}
			main {
				padding: 20px 24px;
				width: 100%;
			}
			.collection-header {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 8px 14px;
				margin-bottom: 16px;
			}
			.collection-title {
				font-size: 30px;
				font-weight: 700;
			}
			.collection-search {
				width: min(420px, 100%);
			}
			.collection-search-input {
				width: 100%;
				padding: 10px 12px;
				border-radius: 8px;
				border: 1px solid #3a5064;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
			}
			.collection-status {
				font-size: 13px;
				color: #b9c9d6;
				margin-bottom: 12px;
			}
			.collection-empty {
				border: 1px solid #314355;
				background: #111923;
				border-radius: 12px;
				padding: 20px;
				color: #b9c9d6;
			}
			.table-wrap {
				overflow: auto;
				border: 1px solid #314355;
				border-radius: 12px;
				background: #111923;
			}
			table {
				width: 100%;
				border-collapse: collapse;
				table-layout: fixed;
			}
			thead th:first-child,
			tbody td:first-child {
				width: 320px;
			}
			thead th:nth-child(2),
			tbody td:nth-child(2) {
				width: 260px;
			}
			thead th:nth-child(4),
			tbody td:nth-child(4) {
				text-align: center;
				width: 100px;
			}
			thead th:nth-child(5),
			tbody td:nth-child(5) {
				width: 70px;
				text-align: center;
			}
			thead th:nth-child(6),
			tbody td:nth-child(6) {
				white-space: nowrap;
				width: 230px;
			}
			thead th:last-child,
			tbody td:last-child {
				white-space: nowrap;
				width: 120px;
				text-align: right;
			}
			thead th {
				position: sticky;
				top: 0;
				z-index: 2;
				background: #1a2835;
				color: #dbe8f5;
				text-align: left;
				font-size: 12px;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				padding: 12px;
				border-bottom: 1px solid #314355;
				cursor: pointer;
				user-select: none;
				white-space: nowrap;
			}
			thead th:hover {
				background: #223344;
			}
			thead th .sort-arrow {
				margin-left: 4px;
				font-size: 10px;
				opacity: 0.4;
			}
			thead th.sort-asc .sort-arrow,
			thead th.sort-desc .sort-arrow {
				opacity: 1;
			}
			.filter-row {
				position: sticky;
				top: 41px;
				z-index: 1;
				background: #15202d;
			}
			.filter-row td {
				padding: 6px 8px;
				border-bottom: 1px solid #314355;
			}
			.filter-select {
				width: 100%;
				padding: 5px 6px;
				border-radius: 5px;
				border: 1px solid #3a5064;
				background: #0d1117;
				color: #fff;
				font-size: 12px;
			}
			tbody td {
				padding: 11px 12px;
				border-bottom: 1px solid #273646;
				font-size: 14px;
				vertical-align: middle;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			tbody tr:last-child td {
				border-bottom: 0;
			}
			tbody tr:nth-child(even) {
				background: #141e28;
			}
			tbody tr:hover {
				background: #172330;
			}
			.card-cell {
				display: flex;
				align-items: center;
				gap: 10px;
			}
			.card-thumb-wrap {
				position: relative;
				width: 44px;
				height: 62px;
				border-radius: 6px;
				overflow: hidden;
				flex-shrink: 0;
			}
			.card-thumb-wrap.thumb-foil::after,
			.card-thumb-wrap.thumb-etched::after {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				border-radius: 6px;
			}
			.card-thumb-wrap.thumb-foil::after {
				background:
					linear-gradient(115deg, rgba(255, 255, 255, 0.34) 6%, rgba(255, 255, 255, 0.02) 24%, rgba(255, 255, 255, 0.28) 40%, rgba(255, 255, 255, 0.03) 58%, rgba(255, 255, 255, 0.22) 78%, rgba(255, 255, 255, 0.04) 100%),
					linear-gradient(135deg, rgba(147, 197, 253, 0.24) 16%, rgba(244, 114, 182, 0.21) 52%, rgba(250, 204, 21, 0.24) 84%);
				mix-blend-mode: screen;
			}
			.card-thumb-wrap.thumb-etched::after {
				background:
					linear-gradient(120deg, rgba(255, 248, 220, 0.28) 8%, rgba(255, 248, 220, 0.02) 46%, rgba(255, 248, 220, 0.22) 88%),
					linear-gradient(145deg, rgba(245, 158, 11, 0.24) 0%, rgba(120, 53, 15, 0.18) 40%, rgba(253, 230, 138, 0.24) 100%);
				mix-blend-mode: screen;
			}
			.card-thumb {
				width: 44px;
				height: 62px;
				object-fit: cover;
				border-radius: 6px;
				border: 1px solid #2e4254;
				background: #0d1117;
			}
			.card-name {
				font-weight: 600;
				white-space: nowrap;
			}
			.card-sub {
				font-size: 12px;
				color: #9db0bf;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 2px 8px;
				border-radius: 999px;
				font-size: 12px;
				font-weight: 600;
				border: 1px solid #314355;
				background: #172330;
				color: #dbe8f5;
			}
			.badge-white { color: #111; background: #f4f5f7; border-color: #e5e7eb; }
			.badge-blue { color: #dbeafe; background: #1d4ed8; border-color: #1e40af; }
			.badge-black { color: #f3f4f6; background: #111827; border-color: #374151; }
			.badge-red { color: #fee2e2; background: #b91c1c; border-color: #991b1b; }
			.badge-green { color: #dcfce7; background: #166534; border-color: #14532d; }
			.badge-multicolor { color: #fef3c7; background: #7c3aed; border-color: #6d28d9; }
			.badge-colorless { color: #e2e8f0; background: #334155; border-color: #475569; }
			.badge-unknown { color: #cbd5e1; background: #1f2937; border-color: #374151; }
			.qty {
				font-weight: 700;
			}
			.mana-cell {
				display: inline-flex;
				align-items: center;
				gap: 8px;
			}
			.mana-icons {
				display: inline-flex;
				align-items: center;
				gap: 2px;
			}
			.mana-icons .ms {
				font-size: 15px;
				line-height: 1;
			}
			.mana-cmc {
				font-weight: 700;
				color: #dbe8f5;
			}
			.collection-row {
				cursor: pointer;
			}
			.collection-inspector-backdrop {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.72);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 24px;
				z-index: 60;
			}
			.collection-inspector-backdrop[hidden] {
				display: none;
			}
			.collection-inspector-modal {
				width: min(980px, 100%);
				max-height: 84vh;
				overflow: hidden;
				border-radius: 14px;
				border: 1px solid #324457;
				background: #111923;
				display: grid;
				grid-template-columns: minmax(280px, 360px) 1fr;
			}
			.collection-inspector-left {
				padding: 16px;
				border-right: 1px solid #2a3a4a;
				display: flex;
				position: relative;
				justify-content: center;
				align-items: flex-start;
				overflow: auto;
			}
			.collection-inspector-left.inspector-foil::after,
			.collection-inspector-left.inspector-etched::after {
				content: '';
				position: absolute;
				inset: 16px;
				pointer-events: none;
				border-radius: 10px;
			}
			.collection-inspector-left.inspector-foil::after {
				background:
					linear-gradient(115deg, rgba(255, 255, 255, 0.44) 6%, rgba(255, 255, 255, 0.03) 24%, rgba(255, 255, 255, 0.36) 40%, rgba(255, 255, 255, 0.04) 58%, rgba(255, 255, 255, 0.3) 78%, rgba(255, 255, 255, 0.06) 100%),
					linear-gradient(135deg, rgba(147, 197, 253, 0.28) 16%, rgba(244, 114, 182, 0.24) 52%, rgba(250, 204, 21, 0.28) 84%);
				mix-blend-mode: screen;
			}
			.collection-inspector-left.inspector-etched::after {
				background:
					linear-gradient(120deg, rgba(255, 248, 220, 0.34) 8%, rgba(255, 248, 220, 0.03) 46%, rgba(255, 248, 220, 0.28) 88%),
					linear-gradient(145deg, rgba(245, 158, 11, 0.3) 0%, rgba(120, 53, 15, 0.2) 40%, rgba(253, 230, 138, 0.3) 100%);
				mix-blend-mode: screen;
			}
			.collection-inspector-image {
				width: 100%;
				max-width: 320px;
				border-radius: 10px;
				box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45);
				display: block;
			}
			.collection-inspector-right {
				display: flex;
				flex-direction: column;
				min-height: 0;
			}
			.collection-inspector-header {
				padding: 14px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 10px;
				border-bottom: 1px solid #2a3a4a;
			}
			.collection-inspector-title {
				font-size: 16px;
				font-weight: 700;
				color: #e7f0f8;
			}
			.collection-inspector-meta,
			.collection-inspector-price {
				margin-top: 4px;
				font-size: 12px;
				color: #9db0bf;
			}
			.collection-inspector-close {
				padding: 8px 10px;
				border-radius: 8px;
				border: 0;
				background: #2e404f;
				color: #fff;
				cursor: pointer;
				font-size: 12px;
				line-height: 1;
			}
			.collection-inspector-close:hover {
				background: #3d5a6e;
			}
			.collection-inspector-controls {
				padding: 12px 14px;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 10px;
				border-bottom: 1px solid #2a3a4a;
			}
			.collection-inspector-field {
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.collection-inspector-label {
				font-size: 12px;
				color: #9db0bf;
				font-weight: 600;
			}
			.collection-inspector-qty-control {
				display: flex;
				align-items: center;
				gap: 6px;
			}
			.collection-inspector-qty-input {
				width: 60px;
				padding: 8px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
				text-align: center;
				font-weight: 700;
			}
			.collection-inspector-qty-btn {
				padding: 6px 8px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				cursor: pointer;
				font-size: 14px;
				font-weight: 600;
				line-height: 1;
			}
			.collection-inspector-qty-btn:hover {
				background: #1a2635;
			}
			.collection-inspector-select {
				padding: 8px 10px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				font-size: 13px;
			}
			.collection-inspector-actions {
				padding: 12px 14px;
				display: flex;
				gap: 8px;
				border-bottom: 1px solid #2a3a4a;
			}
			.collection-inspector-delete-btn {
				padding: 8px 12px;
				border: 1px solid #8b1d1d;
				border-radius: 6px;
				background: #c03636;
				color: #fff;
				cursor: pointer;
				font-size: 12px;
				font-weight: 600;
			}
			.collection-inspector-delete-btn:hover {
				background: #dc4a4a;
			}
			.collection-inspector-errata {
				padding: 12px 14px;
				display: flex;
				flex-direction: column;
				gap: 6px;
				min-height: 0;
				overflow: auto;
			}
			.collection-inspector-errata-title {
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: #dbe8f5;
			}
			.collection-inspector-errata-text {
				white-space: pre-wrap;
				line-height: 1.4;
				font-size: 13px;
				color: #c6d4e1;
			}
			.collection-inspector-errata-text .ms {
				font-size: 15px;
				line-height: 1;
				margin: 0 1px;
			}
			.collection-inspector-controls {
				padding: 12px 14px;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 10px;
				border-bottom: 1px solid #2a3a4a;
			}
			.collection-inspector-field {
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.collection-inspector-label {
				font-size: 12px;
				color: #9db0bf;
				font-weight: 600;
			}
			.collection-inspector-qty-control {
				display: flex;
				align-items: center;
				gap: 6px;
			}
			.collection-inspector-qty-input {
				width: 60px;
				padding: 8px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				font-size: 14px;
				text-align: center;
				font-weight: 700;
			}
			.collection-inspector-qty-btn {
				padding: 6px 8px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				cursor: pointer;
				font-size: 14px;
				font-weight: 600;
				line-height: 1;
			}
			.collection-inspector-qty-btn:hover {
				background: #1a2635;
			}
			.collection-inspector-select {
				padding: 8px 10px;
				border: 1px solid #3a5064;
				border-radius: 6px;
				background: #0d1117;
				color: #fff;
				font-size: 13px;
			}
			.collection-inspector-actions {
				padding: 12px 14px;
				display: flex;
				gap: 8px;
				border-bottom: 1px solid #2a3a4a;
			}
			.collection-inspector-delete-btn {
				padding: 8px 12px;
				border: 1px solid #8b1d1d;
				border-radius: 6px;
				background: #c03636;
				color: #fff;
				cursor: pointer;
				font-size: 12px;
				font-weight: 600;
			}
			.collection-inspector-delete-btn:hover {
				background: #dc4a4a;
			}
			@media (max-width: 900px) {
				main {
					padding: 14px;
				}
				.collection-title {
					font-size: 26px;
				}
				.collection-search {
					width: 100%;
				}
				.collection-inspector-modal {
					grid-template-columns: 1fr;
				}
				.collection-inspector-left {
					border-right: 0;
					border-bottom: 1px solid #2a3a4a;
				}
				.collection-inspector-header {
					flex-direction: column;
					align-items: flex-start;
				}
			}
		</style>
	</head>
	<body>
		<nav class="nav">
			<a href="/Moltencollection/" class="nav-btn">Home</a>
			<a href="/Moltencollection/binders" class="nav-btn">My Binders</a>
			<a href="/Moltencollection/deck" class="nav-btn">My Decks</a>
			<a href="/Moltencollection/collections" class="nav-btn active">Collection</a>
		</nav>

		<!-- Public View button and label removed -->

		<main>
					<!-- Viewer mode banner removed -->
			<div class="collection-header">
				<h1 class="collection-title">Collection</h1>
				<div class="collection-search">
					<input id="collection-search-input" class="collection-search-input" type="text" placeholder="Search cards, type, set, color..." autocomplete="off" />
				</div>
			</div>
			<div id="collection-status" class="collection-status" hidden></div>
			<div id="collection-empty" class="collection-empty" hidden>No cards found in your binders yet.</div>
			<div id="collection-table-wrap" class="table-wrap" hidden>
				<table>
					<thead>
						<tr id="collection-header-row">
							<th data-sort="name">Card</th>
							<th data-sort="type">Type</th>
							<th data-sort="color">Color</th>
							<th data-sort="cmc">Mana Value</th>
							<th data-sort="qty">Qty</th>
							<th data-sort="set">Set</th>
							<th data-sort="finish">Finish</th>
							<th data-sort="lang">Language</th>
							<th data-sort="location">Location</th>
							<th data-sort="price">Price <span class="sort-arrow">▲</span></th>
						</tr>
						<tr class="filter-row">
							<td></td>
							<td><select id="filter-type" class="filter-select"><option value="">All Types</option></select></td>
							<td><select id="filter-color" class="filter-select"><option value="">All Colors</option></select></td>
							<td></td>
							<td></td>
							<td><select id="filter-set" class="filter-select"><option value="">All Sets</option></select></td>
							<td><select id="filter-finish" class="filter-select"><option value="">All Finishes</option></select></td>
							<td><select id="filter-lang" class="filter-select"><option value="">All Languages</option></select></td>
							<td><select id="filter-location" class="filter-select"><option value="">All Locations</option></select></td>
							<td></td>
						</tr>
					</thead>
					<tbody id="collection-body"></tbody>
				</table>
			</div>

			<div id="collection-inspector-backdrop" class="collection-inspector-backdrop" hidden>
				<div class="collection-inspector-modal" role="dialog" aria-modal="true" aria-labelledby="collection-inspector-title">
					<div class="collection-inspector-left">
						<img id="collection-inspector-image" class="collection-inspector-image" alt="Card" src="/Moltencollection/favicon.svg" />
					</div>
					<div class="collection-inspector-right">
						<div class="collection-inspector-header">
							<div>
								<div id="collection-inspector-title" class="collection-inspector-title">Card</div>
								<div id="collection-inspector-meta" class="collection-inspector-meta"></div>
								<div id="collection-inspector-price" class="collection-inspector-price"></div>
							</div>
							<button id="collection-inspector-close" class="collection-inspector-close" type="button" aria-label="Close">&times;</button>
						</div>
						<div class="collection-inspector-controls auth-required">
							<div class="collection-inspector-field">
								<label for="collection-qty-input" class="collection-inspector-label">Quantity</label>
								<div class="collection-inspector-qty-control">
									<button id="collection-qty-minus" class="collection-inspector-qty-btn" type="button">−</button>
									<input id="collection-qty-input" class="collection-inspector-qty-input" type="number" min="1" max="999" value="1" />
									<button id="collection-qty-plus" class="collection-inspector-qty-btn" type="button">+</button>
								</div>
							</div>
							<div class="collection-inspector-field">
								<label for="collection-foil-select" class="collection-inspector-label">Finish</label>
								<select id="collection-foil-select" class="collection-inspector-select">
									<option value="nonfoil">Nonfoil</option>
									<option value="foil">Foil</option>
									<option value="etched">Etched</option>
								</select>
							</div>
						</div>
						<div class="collection-inspector-actions">
							<button id="collection-delete-btn" class="collection-inspector-delete-btn auth-required" type="button">Delete Card</button>
						</div>
						<div class="collection-inspector-errata">
							<div class="collection-inspector-errata-title">Oracle Text</div>
							<div id="collection-inspector-errata" class="collection-inspector-errata-text">Loading...</div>
						</div>
					</div>
				</div>
			</div>
		</main>

		<script>
			type SlotCard = {
				id: string;
				name: string;
				imageUrl: string | null;
				imageUrlLarge?: string | null;
				scryfallUri: string;
				setCode?: string;
				setName?: string;
				collectorNumber?: string;
				lang?: string;
				foil?: 'nonfoil' | 'foil' | 'etched';
				collectionSource?: string;
			};

			type SlotValue = SlotCard | string | null;

			type Binder = {
				id: number;
				name: string;
				description: string;
				color: string;
				pages: SlotValue[][];
			};

			type CardMeta = {
				colorIdentity: string[];
				manaCost: string;
				cmc: number;
				typeLine: string;
				priceEur: string;
				priceEurFoil: string;
				priceUsd: string;
				priceUsdFoil: string;
			};

			type ScryfallOracleCard = {
				type_line?: string;
				oracle_text?: string;
				card_faces?: Array<{
					type_line?: string;
					oracle_text?: string;
				}>;
			};

			type CollectionRow = {
				count: number;
				card: SlotCard;
				meta: CardMeta;
				binderId?: number;
				pageIdx?: number;
				slotIndices?: number[];
				locationText?: string;
			};

			const STORAGE_KEY = 'mtgBinders';
			const COLLECTION_STORAGE_KEY = 'mtgCollection';
			const META_CACHE_KEY = 'mtgCollectionCardMeta';
			const COVER_PAGE_INDEX = 0;

			const collectionStatus = document.getElementById('collection-status') as HTMLElement;
			const collectionEmpty = document.getElementById('collection-empty') as HTMLElement;
			const tableWrap = document.getElementById('collection-table-wrap') as HTMLElement;
			const collectionBody = document.getElementById('collection-body') as HTMLElement;
			const collectionSearchInput = document.getElementById('collection-search-input') as HTMLInputElement;
			const collectionInspectorBackdrop = document.getElementById('collection-inspector-backdrop') as HTMLDivElement;
			const collectionInspectorLeft = document.querySelector('.collection-inspector-left') as HTMLDivElement;
			const collectionInspectorImage = document.getElementById('collection-inspector-image') as HTMLImageElement;
			const collectionInspectorTitle = document.getElementById('collection-inspector-title') as HTMLDivElement;
			const collectionInspectorMeta = document.getElementById('collection-inspector-meta') as HTMLDivElement;
			const collectionInspectorPrice = document.getElementById('collection-inspector-price') as HTMLDivElement;
			const collectionInspectorErrata = document.getElementById('collection-inspector-errata') as HTMLDivElement;
			const collectionInspectorClose = document.getElementById('collection-inspector-close') as HTMLButtonElement;
			const collectionQtyInput = document.getElementById('collection-qty-input') as HTMLInputElement;
			const collectionQtyMinus = document.getElementById('collection-qty-minus') as HTMLButtonElement;
			const collectionQtyPlus = document.getElementById('collection-qty-plus') as HTMLButtonElement;
			const collectionFoilSelect = document.getElementById('collection-foil-select') as HTMLSelectElement;
			const collectionDeleteBtn = document.getElementById('collection-delete-btn') as HTMLButtonElement;

			let inspectedCollectionRow: CollectionRow | null = null;
			let inspectedBinderId: number | null = null;
			let inspectedPageIdx = 0;
			let inspectedSlotIndices: number[] = [];
			let inspectorOracleToken = 0;
			const inspectorOracleCache = new Map<string, string>();

			const readBinders = (): Binder[] => {
				try {
					const raw = localStorage.getItem(STORAGE_KEY);
					return raw ? (JSON.parse(raw) as Binder[]) : [];
				} catch {
					return [];
				}
			};

			const saveBinders = (binders: Binder[]): void => {
				localStorage.setItem(STORAGE_KEY, JSON.stringify(binders));
			};

				// Public view logic removed; now only local collection logic remains

			const readMetaCache = (): Record<string, CardMeta> => {
				try {
					const raw = localStorage.getItem(META_CACHE_KEY);
					return raw ? (JSON.parse(raw) as Record<string, CardMeta>) : {};
				} catch {
					return {};
				}
			};

			const writeMetaCache = (cache: Record<string, CardMeta>): void => {
				localStorage.setItem(META_CACHE_KEY, JSON.stringify(cache));
			};

			const asSlotCard = (slot: SlotValue): SlotCard | null => {
				if (!slot || typeof slot !== 'object') return null;
				if (!('id' in slot) || !('name' in slot)) return null;
				return slot as SlotCard;
			};

			const collectionVariantKey = (card: SlotCard): string => {
				return [card.id, card.lang ?? '', card.foil ?? 'nonfoil'].join('|');
			};

			const collectionSourceKey = (card: SlotCard, binderId: number): string => {
				return (card.collectionSource ?? `binder:${binderId}`).trim().toLowerCase();
			};

			const fetchCardMeta = async (card: SlotCard): Promise<CardMeta> => {
				const fallback: CardMeta = {
					colorIdentity: [],
					manaCost: '',
					cmc: 0,
					typeLine: '',
					priceEur: '',
					priceEurFoil: '',
					priceUsd: '',
					priceUsdFoil: ''
				};
				try {
					if (card.id) {
						const byId = await fetch(`https://api.scryfall.com/cards/${encodeURIComponent(card.id)}`);
						if (byId.ok) {
							const data = await byId.json() as {
								color_identity?: string[];
								mana_cost?: string;
								cmc?: number;
								type_line?: string;
								prices?: {
									eur?: string | null;
									eur_foil?: string | null;
									usd?: string | null;
									usd_foil?: string | null;
								};
							};
							return {
								colorIdentity: Array.isArray(data.color_identity) ? data.color_identity : [],
								manaCost: data.mana_cost ?? '',
								cmc: Number.isFinite(data.cmc) ? Number(data.cmc) : 0,
								typeLine: data.type_line ?? '',
								priceEur: data.prices?.eur ?? '',
								priceEurFoil: data.prices?.eur_foil ?? '',
								priceUsd: data.prices?.usd ?? '',
								priceUsdFoil: data.prices?.usd_foil ?? ''
							};
						}
					}

					if (card.scryfallUri) {
						const response = await fetch(`${card.scryfallUri}?format=json`);
						if (response.ok) {
							const data = await response.json() as {
								color_identity?: string[];
								mana_cost?: string;
								cmc?: number;
								type_line?: string;
								prices?: {
									eur?: string | null;
									eur_foil?: string | null;
									usd?: string | null;
									usd_foil?: string | null;
								};
							};
							return {
								colorIdentity: Array.isArray(data.color_identity) ? data.color_identity : [],
								manaCost: data.mana_cost ?? '',
								cmc: Number.isFinite(data.cmc) ? Number(data.cmc) : 0,
								typeLine: data.type_line ?? '',
								priceEur: data.prices?.eur ?? '',
								priceEurFoil: data.prices?.eur_foil ?? '',
								priceUsd: data.prices?.usd ?? '',
								priceUsdFoil: data.prices?.usd_foil ?? ''
							};
						}
					}
				} catch {
					return fallback;
				}
				return fallback;
			};

			const colorGroup = (colorIdentity: string[]): string => {
				if (!Array.isArray(colorIdentity) || colorIdentity.length === 0) return 'Colorless';
				if (colorIdentity.length > 1) return 'Multicolor';
				const code = colorIdentity[0];
				if (code === 'W') return 'White';
				if (code === 'U') return 'Blue';
				if (code === 'B') return 'Black';
				if (code === 'R') return 'Red';
				if (code === 'G') return 'Green';
				return 'Unknown';
			};

			const colorSortRank = (group: string): number => {
				if (group === 'White') return 0;
				if (group === 'Blue') return 1;
				if (group === 'Black') return 2;
				if (group === 'Red') return 3;
				if (group === 'Green') return 4;
				if (group === 'Multicolor') return 5;
				if (group === 'Colorless') return 6;
				return 7;
			};

			const colorBadgeClass = (group: string): string => {
				if (group === 'White') return 'badge badge-white';
				if (group === 'Blue') return 'badge badge-blue';
				if (group === 'Black') return 'badge badge-black';
				if (group === 'Red') return 'badge badge-red';
				if (group === 'Green') return 'badge badge-green';
				if (group === 'Multicolor') return 'badge badge-multicolor';
				if (group === 'Colorless') return 'badge badge-colorless';
				return 'badge badge-unknown';
			};

			const escapeHtml = (value: string): string => value
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')
				.replaceAll('"', '&quot;')
				.replaceAll("'", '&#39;');

			const manaClassFromSymbol = (symbol: string): string => {
				const normalized = symbol.trim().toUpperCase().replaceAll(' ', '');
				if (normalized === 'T') return 'tap';
				if (normalized === 'Q') return 'untap';

				return symbol
					.trim()
					.toLowerCase()
					.replaceAll('/', '')
					.replaceAll('½', 'half')
					.replaceAll('∞', 'infinity')
					.replaceAll(' ', '');
			};

			const manaCostToHtml = (manaCost: string): string => {
				const symbols = Array.from(manaCost.matchAll(/\{([^}]+)\}/g)).map((match) => match[1]);
				if (symbols.length === 0) return '';

				return symbols
					.map((symbol) => {
						const symbolClass = manaClassFromSymbol(symbol);
						return `<i class="ms ms-cost ms-${escapeHtml(symbolClass)}" title="${escapeHtml(`{${symbol}}`)}" aria-label="${escapeHtml(`{${symbol}}`)}"></i>`;
					})
					.join('');
			};

			const manaTextToHtml = (value: string): string => {
				const pattern = /\{([^}]+)\}/g;
				let html = '';
				let cursor = 0;
				let match = pattern.exec(value);

				while (match) {
					html += escapeHtml(value.slice(cursor, match.index));
					const symbol = match[1];
					const symbolClass = manaClassFromSymbol(symbol);
					html += `<i class="ms ms-cost ms-${escapeHtml(symbolClass)}" title="${escapeHtml(`{${symbol}}`)}" aria-label="${escapeHtml(`{${symbol}}`)}"></i>`;
					cursor = match.index + match[0].length;
					match = pattern.exec(value);
				}

				html += escapeHtml(value.slice(cursor));
				return html.replaceAll('\n', '<br />');
			};

			const langToFlag = (langCode: string | undefined): string => {
				switch (langCode) {
					case 'en': return '🇺🇸';
					case 'es': return '🇪🇸';
					case 'fr': return '🇫🇷';
					case 'de': return '🇩🇪';
					case 'it': return '🇮🇹';
					case 'pt': return '🇧🇷';
					case 'ja': return '🇯🇵';
					case 'ko': return '🇰🇷';
					case 'ru': return '🇷🇺';
					case 'zhs': return '🇨🇳';
					case 'zht': return '🇹🇼';
					default: return '❓';
				}
			};

			const buildOracleText = (card: ScryfallOracleCard): string => {
				if (card.oracle_text?.trim()) {
					const typeLine = card.type_line?.trim() ? `${card.type_line}\n\n` : '';
					return `${typeLine}${card.oracle_text.trim()}`;
				}

				if (card.card_faces && card.card_faces.length > 0) {
					const parts = card.card_faces
						.map((face) => {
							const line = face.type_line?.trim() ? `${face.type_line}\n` : '';
							const text = face.oracle_text?.trim() ?? '';
							return `${line}${text}`.trim();
						})
						.filter(Boolean);
					if (parts.length > 0) return parts.join('\n\n//\n\n');
				}

				return 'No oracle text available.';
			};

			const formatPrice = (meta: CardMeta, foil: SlotCard['foil']): string => {
				const isFoil = foil === 'foil' || foil === 'etched';
				const preferredEur = isFoil ? meta.priceEurFoil : meta.priceEur;
				const fallbackEur = isFoil ? meta.priceEur : meta.priceEurFoil;
				const preferredUsd = isFoil ? meta.priceUsdFoil : meta.priceUsd;
				const fallbackUsd = isFoil ? meta.priceUsd : meta.priceUsdFoil;

				if (preferredEur) return `EUR ${preferredEur}`;
				if (fallbackEur) return `EUR ${fallbackEur}`;
				if (preferredUsd) return `USD ${preferredUsd}`;
				if (fallbackUsd) return `USD ${fallbackUsd}`;
				return '—';
			};

			const closeCollectionInspector = (): void => {
				inspectedCollectionRow = null;
				collectionInspectorBackdrop.hidden = true;
			};

			const loadInspectorOracleText = async (cardId: string): Promise<void> => {
				const token = ++inspectorOracleToken;

				const applyIfCurrent = (text: string): void => {
					if (!inspectedCollectionRow || inspectedCollectionRow.card.id !== cardId || token !== inspectorOracleToken) return;
					collectionInspectorErrata.innerHTML = manaTextToHtml(text);
				};

				const cached = inspectorOracleCache.get(cardId);
				if (cached) {
					applyIfCurrent(cached);
					return;
				}

				try {
					const response = await fetch(`https://api.scryfall.com/cards/${encodeURIComponent(cardId)}`);
					if (!response.ok) {
						applyIfCurrent(`Failed to load oracle text (HTTP ${response.status}).`);
						return;
					}

					const payload = await response.json() as ScryfallOracleCard;
					const text = buildOracleText(payload);
					inspectorOracleCache.set(cardId, text);
					applyIfCurrent(text);
				} catch {
					applyIfCurrent('Network error while loading oracle text.');
				}
			};

			const openCollectionInspector = (row: CollectionRow): void => {
				inspectedCollectionRow = row;
				inspectedBinderId = row.binderId ?? null;
				inspectedPageIdx = row.pageIdx ?? 0;
				inspectedSlotIndices = row.slotIndices ?? [];
				
				const image = row.card.imageUrlLarge || row.card.imageUrl || '/favicon.svg';
				const setLabel = row.card.setCode ? row.card.setCode.toUpperCase() : '';
				const finishText = row.card.foil === 'foil' ? 'Foil' : row.card.foil === 'etched' ? 'Etched' : 'Nonfoil';
				const langFlag = row.card.lang ? langToFlag(row.card.lang) : '';
				const metaParts = [
					row.meta.typeLine,
					row.card.setName,
					setLabel,
					row.card.collectorNumber ? `#${row.card.collectorNumber}` : '',
					langFlag,
					finishText,
					`${row.count} in collection`
				].filter((part) => Boolean(part));

				collectionInspectorImage.src = image;
				collectionInspectorImage.alt = row.card.name;
				collectionInspectorLeft.classList.remove('inspector-foil', 'inspector-etched');
				if (row.card.foil === 'foil') {
					collectionInspectorLeft.classList.add('inspector-foil');
				} else if (row.card.foil === 'etched') {
					collectionInspectorLeft.classList.add('inspector-etched');
				}
				collectionInspectorTitle.textContent = row.card.name;
				collectionInspectorMeta.textContent = metaParts.join(' · ');
				collectionInspectorPrice.textContent = formatPrice(row.meta, row.card.foil);
				collectionInspectorErrata.textContent = 'Loading oracle text...';
				
				collectionQtyInput.value = String(row.count);
				collectionFoilSelect.value = row.card.foil ?? 'nonfoil';
				
				collectionInspectorBackdrop.hidden = false;
				void loadInspectorOracleText(row.card.id);
			};

			const saveCollectionChanges = async (): Promise<void> => {
				if (!inspectedCollectionRow || inspectedBinderId === null) return;

				const newQty = Math.max(1, Math.min(999, Number.parseInt(collectionQtyInput.value, 10) || 1));
				const newFoil = collectionFoilSelect.value as 'nonfoil' | 'foil' | 'etched';
				
				const binders = readBinders();
				const binder = binders.find((b) => b.id === inspectedBinderId);
				if (!binder) return;

				const pages = Array.isArray(binder.pages) ? binder.pages : [];
				if (!pages[inspectedPageIdx] || !Array.isArray(pages[inspectedPageIdx])) return;

				const page = pages[inspectedPageIdx];
				const currentQty = inspectedSlotIndices.length;

				if (newQty < currentQty) {
					const slotsToRemove = currentQty - newQty;
					for (let i = 0; i < slotsToRemove; i += 1) {
						const slotIdx = inspectedSlotIndices[currentQty - 1 - i];
						if (slotIdx !== undefined && slotIdx < page.length) {
							page[slotIdx] = null;
						}
					}
					inspectedSlotIndices = inspectedSlotIndices.slice(0, newQty);
				} else if (newQty > currentQty) {
					const slotsToAdd = newQty - currentQty;
					for (let i = 0; i < slotsToAdd; i += 1) {
						const emptySlot = page.findIndex((slot) => slot === null || slot === '');
						if (emptySlot !== -1) {
							page[emptySlot] = { ...inspectedCollectionRow.card, foil: newFoil };
							inspectedSlotIndices.push(emptySlot);
						}
					}
				}

				if (newFoil !== (inspectedCollectionRow.card.foil ?? 'nonfoil')) {
					for (const slotIdx of inspectedSlotIndices) {
						if (slotIdx < page.length && page[slotIdx]) {
							const slot = page[slotIdx];
							if (slot && typeof slot === 'object') {
								(slot as Partial<SlotCard>).foil = newFoil;
							}
						}
					}
					inspectedCollectionRow.card.foil = newFoil;
				}

				inspectedCollectionRow.count = newQty;
				binder.pages = pages;
				saveBinders(binders);
				await buildCollection();
				
				const updatedRow = Array.from(collectionBody.querySelectorAll('tr')).find(
					(tr) => (tr.dataset.search ?? '').includes(inspectedCollectionRow!.card.name)
				);
				if (updatedRow) {
					const pos = updatedRow.getBoundingClientRect();
					if (pos.top >= 0 && pos.top < window.innerHeight) {
						updatedRow.scrollIntoView({ behavior: 'smooth' });
					}
				}
			};

			const deleteCollectionCard = async (): Promise<void> => {
				if (!inspectedCollectionRow || inspectedBinderId === null) return;

				if (inspectedBinderId === -1) {
					// Standalone collection card — remove from mtgCollection
					const cards = readCollectionCards();
					const key = collectionVariantKey(inspectedCollectionRow.card);
					const updated = cards.filter((c) => collectionVariantKey(c) !== key);
					await saveCollectionCards(updated);
				} else {
					// Binder card — null out slot(s)
					const binders = readBinders();
					const binder = binders.find((b) => b.id === inspectedBinderId);
					if (!binder) return;

					const pages = Array.isArray(binder.pages) ? binder.pages : [];
					if (!pages[inspectedPageIdx] || !Array.isArray(pages[inspectedPageIdx])) return;

					const page = pages[inspectedPageIdx];

					for (const slotIdx of inspectedSlotIndices) {
						if (slotIdx < page.length) {
							page[slotIdx] = null;
						}
					}

					binder.pages = pages;
					saveBinders(binders);
				}

				closeCollectionInspector();
				await buildCollection();
			};

			const applyCollectionFilter = (): void => {
				const term = collectionSearchInput.value.trim().toLowerCase();
				const filterType = (document.getElementById('filter-type') as HTMLSelectElement).value;
				const filterColor = (document.getElementById('filter-color') as HTMLSelectElement).value;
				const filterSet = (document.getElementById('filter-set') as HTMLSelectElement).value;
				const filterFinish = (document.getElementById('filter-finish') as HTMLSelectElement).value;
				const filterLang = (document.getElementById('filter-lang') as HTMLSelectElement).value;
				const filterLocation = (document.getElementById('filter-location') as HTMLSelectElement).value;
				const rows = Array.from(collectionBody.querySelectorAll('tr')) as HTMLTableRowElement[];

				let visibleCount = 0;
				rows.forEach((row) => {
					const haystack = (row.dataset.search ?? '').toLowerCase();
					let visible = term.length < 2 || haystack.includes(term);
					if (visible && filterType && !(row.dataset.type ?? '').includes(filterType.toLowerCase())) visible = false;
					if (visible && filterColor && row.dataset.color !== filterColor) visible = false;
					if (visible && filterSet && !(row.dataset.set ?? '').startsWith(filterSet.toLowerCase())) visible = false;
					if (visible && filterFinish && row.dataset.finish !== filterFinish) visible = false;
					if (visible && filterLang && row.dataset.lang !== filterLang) visible = false;
					if (visible && filterLocation && !(row.dataset.location ?? '').includes(filterLocation)) visible = false;
					row.hidden = !visible;
					if (visible) visibleCount += 1;
				});

				if (rows.length === 0) {
					return;
				}

				const hasAnyFilter = term.length >= 2 || filterType || filterColor || filterSet || filterFinish || filterLang || filterLocation;
				if (hasAnyFilter) {
					collectionStatus.textContent = `Showing ${visibleCount} of ${rows.length} card variant${rows.length === 1 ? '' : 's'}.`;
				} else {
					collectionStatus.textContent = `Showing ${rows.length} card variant${rows.length === 1 ? '' : 's'} from binder data.`;
				}
			};

			const buildCollection = async (): Promise<void> => {
				try {
					collectionStatus.textContent = 'Reading binders...';
					collectionBody.innerHTML = '';
					collectionEmpty.hidden = true;
					tableWrap.hidden = true;

					const binders = readBinders();
					const counts = new Map<string, { count: number; card: SlotCard; binderId: number; pageIdx: number; slotIndices: number[]; locations: Set<string> }>();
					const seenSources = new Set<string>();

					// Add cards from collection storage
					const collectionCards = readCollectionCards();
					collectionCards.forEach((card, index) => {
						const variantKey = collectionVariantKey(card);
						const source = card.collectionSource ?? 'Collection';
						const locationName = source.startsWith('deck:') ? source.slice(5) : 'Collection';
						const existing = counts.get(variantKey);
						if (existing) {
							existing.count += 1;
							existing.locations.add(locationName);
						} else {
							counts.set(variantKey, { count: 1, card, binderId: -1, pageIdx: 0, slotIndices: [index], locations: new Set([locationName]) });
						}
					});

					binders.forEach((binder) => {
						const pages = Array.isArray(binder.pages) ? binder.pages : [];
						pages.forEach((page, pageIdx) => {
							if (pageIdx === COVER_PAGE_INDEX || !Array.isArray(page)) return;
							page.forEach((slot, slotIdx) => {
								const card = asSlotCard(slot);
								if (!card) return;
								const variantKey = collectionVariantKey(card);
								const sourceKey = collectionSourceKey(card, binder.id);
								const sourceVariantKey = `${variantKey}|${sourceKey}`;
								if (seenSources.has(sourceVariantKey)) return;
								seenSources.add(sourceVariantKey);
								const existing = counts.get(variantKey);
								if (existing) {
									existing.count += 1;
									existing.slotIndices.push(slotIdx);
									existing.locations.add(binder.name);
								} else {
									counts.set(variantKey, { count: 1, card, binderId: binder.id, pageIdx, slotIndices: [slotIdx], locations: new Set([binder.name]) });
								}
							});
						});
					});

					if (counts.size === 0) {
						collectionStatus.textContent = 'No cards in collection yet.';
						collectionEmpty.hidden = false;
						return;
					}

					collectionStatus.textContent = `Loading metadata for ${counts.size} card variant${counts.size === 1 ? '' : 's'}...`;
					const metaCache = readMetaCache();
					const rows: CollectionRow[] = [];

					for (const entry of counts.values()) {
						let meta = metaCache[entry.card.id];
						if (!meta || typeof meta.priceEur !== 'string' || typeof meta.typeLine !== 'string') {
							meta = await fetchCardMeta(entry.card);
							metaCache[entry.card.id] = meta;
						}
						rows.push({
							count: entry.count,
							card: entry.card,
							meta,
							binderId: entry.binderId,
							pageIdx: entry.pageIdx,
							slotIndices: entry.slotIndices,
							locationText: Array.from(entry.locations).map(s => s.charAt(0).toUpperCase() + s.slice(1)).sort().join(', ')
						});
					}

					writeMetaCache(metaCache);

					rows.sort((a, b) => {
						const groupA = colorGroup(a.meta.colorIdentity);
						const groupB = colorGroup(b.meta.colorIdentity);
						const rankA = colorSortRank(groupA);
						const rankB = colorSortRank(groupB);
						if (rankA !== rankB) return rankA - rankB;

						if (a.meta.cmc !== b.meta.cmc) return a.meta.cmc - b.meta.cmc;

						const manaA = a.meta.manaCost || '';
						const manaB = b.meta.manaCost || '';
						if (manaA !== manaB) return manaA.localeCompare(manaB);
						return a.card.name.localeCompare(b.card.name);
					});

					for (const row of rows) {
						const group = colorGroup(row.meta.colorIdentity);
						const setText = `${row.card.setName ?? 'Unknown Set'}${row.card.collectorNumber ? ` #${row.card.collectorNumber}` : ''}`;
						const finishText = row.card.foil ?? 'nonfoil';
						const langText = (row.card.lang ?? 'en').toUpperCase();
						const locationText = row.locationText || '—';
						const priceText = formatPrice(row.meta, row.card.foil);
						const manaCostHtml = manaCostToHtml(row.meta.manaCost || '');
						const cmcText = row.meta.cmc.toString();

						const tr = document.createElement('tr');
						tr.dataset.search = [
							row.card.name,
							row.meta.typeLine,
							group,
							setText,
							finishText,
							langText,
							locationText,
							priceText
						].join(' ').toLowerCase();
						tr.dataset.name = row.card.name.toLowerCase();
						tr.dataset.type = (row.meta.typeLine || '').toLowerCase();
						tr.dataset.color = group;
						tr.dataset.cmc = String(row.meta.cmc);
						tr.dataset.qty = String(row.count);
						tr.dataset.set = setText.toLowerCase();
						tr.dataset.finish = finishText;
						tr.dataset.lang = langText;
						tr.dataset.location = locationText;
						tr.dataset.price = String(parseFloat((priceText.match(/[\d.]+/) || ['0'])[0]) || 0);
						tr.innerHTML = `
							<td>
								<div class="card-cell">
									<span class="card-thumb-wrap ${row.card.foil === 'foil' ? 'thumb-foil' : row.card.foil === 'etched' ? 'thumb-etched' : ''}">
										<img class="card-thumb" src="${escapeHtml(row.card.imageUrl ?? '/favicon.svg')}" alt="${escapeHtml(row.card.name)}" loading="lazy" />
									</span>
									<div>
										<div class="card-name">${escapeHtml(row.card.name)}</div>
									</div>
								</div>
							</td>
							<td>${escapeHtml(row.meta.typeLine || '—')}</td>
							<td><span class="${colorBadgeClass(group)}">${escapeHtml(group)}</span></td>
							<td><span class="mana-cell">${manaCostHtml ? `<span class="mana-icons">${manaCostHtml}</span>` : ''}<span class="mana-cmc">${escapeHtml(cmcText)}</span></span></td>
							<td class="qty">${row.count}</td>
							<td>${escapeHtml(setText)}</td>
							<td>${escapeHtml(finishText)}</td>
							<td>${escapeHtml(langText)}</td>
							<td>${escapeHtml(locationText)}</td>
							<td>${escapeHtml(priceText)}</td>
						`;
						tr.classList.add('collection-row');
						tr.tabIndex = 0;
						tr.setAttribute('role', 'button');
						tr.setAttribute('aria-label', `Open details for ${row.card.name}`);
						tr.addEventListener('click', () => {
							openCollectionInspector(row);
						});
						tr.addEventListener('keydown', (event) => {
							if (event.key !== 'Enter' && event.key !== ' ') return;
							event.preventDefault();
							openCollectionInspector(row);
						});
						collectionBody.appendChild(tr);
					}

					collectionStatus.textContent = `Showing ${rows.length} card variant${rows.length === 1 ? '' : 's'} from binder data.`;
					tableWrap.hidden = false;
					populateFilterDropdowns();
					applyCollectionFilter();
				} catch {
					collectionStatus.textContent = 'Could not load collection data.';
					collectionEmpty.hidden = false;
				}
			};

			void buildCollection();
			collectionSearchInput.addEventListener('input', applyCollectionFilter);

			// --- Sorting ---
			let currentSortKey = '';
			let currentSortDir: 'asc' | 'desc' = 'asc';

			const headerRow = document.getElementById('collection-header-row') as HTMLTableRowElement;
			headerRow.addEventListener('click', (event) => {
				const th = (event.target as HTMLElement).closest('th') as HTMLTableCellElement | null;
				if (!th || !th.dataset.sort) return;
				const key = th.dataset.sort;
				if (currentSortKey === key) {
					currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
				} else {
					currentSortKey = key;
					currentSortDir = 'asc';
				}
				Array.from(headerRow.children).forEach((h) => {
					h.classList.remove('sort-asc', 'sort-desc');
				});
				th.classList.add(currentSortDir === 'asc' ? 'sort-asc' : 'sort-desc');
				const arrow = th.querySelector('.sort-arrow');
				if (arrow) arrow.textContent = currentSortDir === 'asc' ? '\u25B2' : '\u25BC';
				Array.from(headerRow.children).forEach((h) => {
					if (h === th) return;
					const a = h.querySelector('.sort-arrow');
					if (a) a.textContent = '\u25B2';
				});

				const rows = Array.from(collectionBody.querySelectorAll('tr')) as HTMLTableRowElement[];
				rows.sort((a, b) => {
					const aVal = a.dataset[key] ?? '';
					const bVal = b.dataset[key] ?? '';
					const numKeys = ['cmc', 'qty', 'price'];
					let cmp: number;
					if (numKeys.includes(key)) {
						cmp = (parseFloat(aVal) || 0) - (parseFloat(bVal) || 0);
					} else {
						cmp = aVal.localeCompare(bVal);
					}
					return currentSortDir === 'asc' ? cmp : -cmp;
				});
				rows.forEach((row) => collectionBody.appendChild(row));
			});

			// --- Filter dropdowns ---
			function populateFilterDropdowns(): void {
				const rows = Array.from(collectionBody.querySelectorAll('tr.collection-row')) as HTMLTableRowElement[];

				const collectUnique = (getter: (r: HTMLTableRowElement) => string[]): string[] => {
					const vals = new Set<string>();
					for (const r of rows) {
						for (const v of getter(r)) {
							if (v) vals.add(v);
						}
					}
					return Array.from(vals).sort((a, b) => a.localeCompare(b));
				};

				const fillSelect = (id: string, values: string[], allLabel: string): void => {
					const sel = document.getElementById(id) as HTMLSelectElement | null;
					if (!sel) return;
					const current = sel.value;
					while (sel.options.length > 0) sel.remove(0);
					const allOpt = document.createElement('option');
					allOpt.value = '';
					allOpt.textContent = allLabel;
					sel.appendChild(allOpt);
					for (const v of values) {
						const opt = document.createElement('option');
						opt.value = v;
						opt.textContent = v;
						sel.appendChild(opt);
					}
					sel.value = current;
				};

				const typeValues = collectUnique((r) => {
					const t = r.dataset.type ?? '';
					const main = t.split('\u2014')[0].split('—')[0].trim();
					return main.split(/\s+/)
						.filter((w) => w.length > 0)
						.map((w) => w.charAt(0).toUpperCase() + w.slice(1));
				});
				fillSelect('filter-type', typeValues, 'All Types');

				const colorValues = collectUnique((r) => {
					const v = r.dataset.color;
					return v ? [v] : [];
				});
				fillSelect('filter-color', colorValues, 'All Colors');

				const setValues = collectUnique((r) => {
					const s = r.dataset.set ?? '';
					const name = s.replace(/#\d+$/i, '').trim();
					return name ? [name] : [];
				});
				const setSelect = document.getElementById('filter-set') as HTMLSelectElement | null;
				if (setSelect) {
					const currentSet = setSelect.value;
					while (setSelect.options.length > 0) setSelect.remove(0);
					const allOpt = document.createElement('option');
					allOpt.value = '';
					allOpt.textContent = 'All Sets';
					setSelect.appendChild(allOpt);
					for (const v of setValues) {
						const opt = document.createElement('option');
						opt.value = v;
						opt.textContent = v.split(' ').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
						setSelect.appendChild(opt);
					}
					setSelect.value = currentSet;
				}

				const finishValues = collectUnique((r) => {
					const v = r.dataset.finish;
					return v ? [v] : [];
				});
				fillSelect('filter-finish', finishValues, 'All Finishes');

				const langValues = collectUnique((r) => {
					const v = r.dataset.lang;
					return v ? [v] : [];
				});
				fillSelect('filter-lang', langValues, 'All Languages');

				const locationValues = collectUnique((r) => {
					const v = r.dataset.location ?? '';
					return v.split(', ').filter((s) => s && s !== '—');
				});
				fillSelect('filter-location', locationValues, 'All Locations');
			};

			['filter-type', 'filter-color', 'filter-set', 'filter-finish', 'filter-lang', 'filter-location'].forEach((id) => {
				(document.getElementById(id) as HTMLSelectElement).addEventListener('change', applyCollectionFilter);
			});

			collectionInspectorClose.addEventListener('click', closeCollectionInspector);
			collectionQtyMinus.addEventListener('click', () => {
				const current = Math.max(1, Number.parseInt(collectionQtyInput.value, 10) || 1);
				collectionQtyInput.value = String(Math.max(1, current - 1));
				void saveCollectionChanges();
			});
			collectionQtyPlus.addEventListener('click', () => {
				const current = Math.max(1, Number.parseInt(collectionQtyInput.value, 10) || 1);
				collectionQtyInput.value = String(Math.min(999, current + 1));
				void saveCollectionChanges();
			});
			collectionQtyInput.addEventListener('change', () => {
				const value = Math.max(1, Math.min(999, Number.parseInt(collectionQtyInput.value, 10) || 1));
				collectionQtyInput.value = String(value);
				void saveCollectionChanges();
			});
			collectionFoilSelect.addEventListener('change', () => {
				void saveCollectionChanges();
			});
			collectionDeleteBtn.addEventListener('click', () => {
				if (confirm('Delete this card from your collection?')) {
					void deleteCollectionCard();
				}
			});
			collectionInspectorBackdrop.addEventListener('click', (event) => {
				if (event.target === collectionInspectorBackdrop) {
					closeCollectionInspector();
				}
			});
			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && !collectionInspectorBackdrop.hidden) {
					closeCollectionInspector();
				}
			});

			window.addEventListener('storage', (event) => {
				if (event.key === STORAGE_KEY) {
					closeCollectionInspector();
					void buildCollection();
				}
			});
		</script>
	</body>
</html>
